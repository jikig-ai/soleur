# apps/telegram-bridge/.env.example
#
# Required environment variables for the Soleur Telegram Bridge.
# This file is SHARED with web-platform -- both containers read
# from the same /mnt/data/.env via --env-file.
# See apps/web-platform/.env.example for the platform's required keys.

# --- Telegram ---
# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (from @userinfobot). Only this user can interact with the bot.
TELEGRAM_ALLOWED_USER_ID=

# Anthropic API key for Claude Code CLI (required -- without this, the bot
# starts and passes health checks but every Claude invocation fails)
ANTHROPIC_API_KEY=

# Path to Soleur plugin directory (optional, for loading skills/commands)
SOLEUR_PLUGIN_DIR=

# Claude model to use (default: claude-opus-4-6)
CLAUDE_MODEL=

# Set to "false" to disable --dangerously-skip-permissions (default: true for headless)
SKIP_PERMISSIONS=
