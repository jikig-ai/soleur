[
  {
    "id": "deploy",
    "execute-command": "/usr/local/bin/ci-deploy-wrapper.sh",
    "command-working-directory": "/",
    "include-command-output-in-response": false,
    "success-http-response-code": 202,
    "response-message": "Deploy initiated",
    "http-methods": ["POST"],
    "trigger-rule-mismatch-http-response-code": 403,
    "pass-environment-to-command": [
      {
        "source": "payload",
        "name": "command",
        "envname": "SSH_ORIGINAL_COMMAND"
      }
    ],
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": ${jsonencode(webhook_deploy_secret)},
        "parameter": {
          "source": "header",
          "name": "X-Signature-256"
        }
      }
    }
  },
  {
    "id": "infra-config",
    "execute-command": "/usr/local/bin/infra-config-apply.sh",
    "command-working-directory": "/",
    "include-command-output-in-response": false,
    "success-http-response-code": 202,
    "response-message": "Infra config update initiated",
    "http-methods": ["POST"],
    "trigger-rule-mismatch-http-response-code": 403,
    "pass-environment-to-command": [
      { "source": "payload", "name": "ci_deploy_sh_b64", "envname": "CI_DEPLOY_SH_B64" },
      { "source": "payload", "name": "ci_deploy_wrapper_sh_b64", "envname": "CI_DEPLOY_WRAPPER_SH_B64" },
      { "source": "payload", "name": "webhook_service_b64", "envname": "WEBHOOK_SERVICE_B64" },
      { "source": "payload", "name": "cat_deploy_state_sh_b64", "envname": "CAT_DEPLOY_STATE_SH_B64" },
      { "source": "payload", "name": "canary_bundle_claim_check_sh_b64", "envname": "CANARY_BUNDLE_CLAIM_CHECK_SH_B64" },
      { "source": "payload", "name": "deploy_inngest_bootstrap_sudoers_b64", "envname": "DEPLOY_INNGEST_BOOTSTRAP_SUDOERS_B64" },
      { "source": "payload", "name": "hooks_json_b64", "envname": "HOOKS_JSON_B64" }
    ],
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": ${jsonencode(webhook_deploy_secret)},
        "parameter": {
          "source": "header",
          "name": "X-Signature-256"
        }
      }
    }
  },
  {
    "id": "deploy-status",
    "execute-command": "/usr/local/bin/cat-deploy-state.sh",
    "command-working-directory": "/",
    "include-command-output-in-response": true,
    "http-methods": ["GET"],
    "trigger-rule-mismatch-http-response-code": 403,
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": ${jsonencode(webhook_deploy_secret)},
        "parameter": {
          "source": "header",
          "name": "X-Signature-256"
        }
      }
    }
  }
]
