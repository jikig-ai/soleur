{
  "name": "Soleur AI",
  "url": "https://soleur.ai",
  "description": "Soleur connects to your GitHub repositories to enable AI-powered project management and collaboration.",
  "public": false,
  "redirect_url": "https://${app_domain}/internal/github-app-init",
  "hook_attributes": {
    "url": "https://${app_domain}/api/webhooks/github",
    "active": true
  },
  "callback_urls": [
    "https://app.soleur.ai/api/auth/github-resolve/callback",
    "https://api.soleur.ai/auth/v1/callback",
    "https://ifsccnjhymdmidffkzhl.supabase.co/auth/v1/callback"
  ],
  "setup_url": "https://${app_domain}/dashboard/repos",
  "setup_on_update": true,
  "default_permissions": {
    "actions": "write",
    "administration": "write",
    "checks": "write",
    "contents": "write",
    "issues": "write",
    "members": "read",
    "metadata": "read",
    "packages": "read",
    "pages": "write",
    "pull_requests": "write",
    "repository_advisories": "read",
    "secret_scanning_alerts": "read",
    "secrets": "write"
  },
  "default_events": [
    "issues",
    "pull_request",
    "push",
    "repository_advisory",
    "secret_scanning_alert",
    "workflow_run"
  ]
}
