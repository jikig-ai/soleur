{
  "name": "soleur-web-platform",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "next build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node22 --outfile=dist/server/index.cjs --external:next --external:react --external:react-dom --external:@supabase/supabase-js --external:@supabase/ssr --external:ws --external:stripe --external:@anthropic-ai/claude-agent-sdk --external:pino --external:@sentry/nextjs",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "lint": "next lint",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "npx playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.85",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/pino-http": "^6.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.5.14",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "overrides": {
    "vite": "^7.3.2"
  }
}
