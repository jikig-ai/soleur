{
  "name": "soleur-web-platform",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.16.0 || >=22.3.0"
  },
  "scripts": {
    "dev": "esbuild server/index.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=.next/dev-server.mjs && node .next/dev-server.mjs",
    "build": "next build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node22 --outfile=dist/server/index.cjs --external:next --external:react --external:react-dom --external:@supabase/supabase-js --external:@supabase/ssr --external:ws --external:stripe --external:@anthropic-ai/claude-agent-sdk --external:pino --external:@sentry/nextjs --external:pdfjs-dist",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "lint": "next lint",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "npx playwright test",
    "test:rls-fuzz": "RLS_FUZZ_LOCAL=1 vitest run test/rls-fuzz",
    "rls:parity": "tsx scripts/rls-parity-check.ts",
    "typecheck": "tsc --noEmit",
    "hash-user-id": "bun scripts/hash-user-id.ts",
    "byok-grant": "bun scripts/byok-grant.ts",
    "byok-revoke": "bun scripts/byok-revoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.197",
    "@anthropic-ai/claude-code": "2.1.197",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "@likec4/core": "1.50.0",
    "@likec4/diagram": "1.50.0",
    "@mantine/core": "8.3.15",
    "@mantine/hooks": "8.3.15",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.2.0",
    "@playwright/mcp": "0.0.75",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@uiw/react-codemirror": "^4.25.10",
    "archiver": "^8.0.0",
    "cmdk": "^1.1.1",
    "codemirror": "^6",
    "flagsmith-nodejs": "^8.1.0",
    "gray-matter": "^4.0.3",
    "inngest": "^3.54.2",
    "ipaddr.js": "^2.4.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.21",
    "pdfjs-dist": "^5.4.296",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.10.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "stripe": "^17.7.0",
    "svix": "1.92.2",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pino-http": "^6.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "dependency-cruiser": "^16.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.5.18",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": "^7.3.2",
    "brace-expansion": "^5.0.6",
    "ws": "^8.21.0",
    "qs": "^6.15.2",
    "@babel/core": "^7.29.6",
    "protobufjs": "^7.6.4"
  }
}
