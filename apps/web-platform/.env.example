# apps/web-platform/.env.example
#
# Required environment variables for the Soleur Web Platform.
# Production uses Doppler (soleur/prd config) -- ci-deploy.sh downloads
# secrets at deploy time. This file is for local development only.
#
# IMPORTANT: NEXT_PUBLIC_ vars are baked into the Docker image
# at build time via ARG directives. Setting them here only affects
# server-side code (middleware, agent-runner, ws-handler). Client-side
# code uses the values from the Docker build. See the Dockerfile for
# the ARG declarations.

# --- Supabase ---
# Auth and database. Without these, all API calls and auth flows fail.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Payment processing. Without these, checkout and webhook handling break.
STRIPE_SECRET_KEY=
# DEPRECATED: Legacy single-tier price id. Retained only for the pre-
# conversation-slot checkout path; remove once the last caller is on
# targetTier (see #1162 follow-ups).
STRIPE_PRICE_ID=
# Per-tier price IDs used by the upgrade-at-capacity modal and the
# concurrency enforcement webhook. All four must resolve via the Stripe
# API or scripts/verify-stripe-prices.ts fails.
STRIPE_PRICE_ID_SOLO=
STRIPE_PRICE_ID_STARTUP=
STRIPE_PRICE_ID_SCALE=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_WEBHOOK_SECRET=

# --- BYOK Encryption ---
# CRITICAL: This key is the master key for BYOK encryption.
# Per-user keys are derived via HKDF (SHA-256) from this master key + user ID.
# If lost, all BYOK-encrypted keys become PERMANENTLY UNRECOVERABLE.
# BACK UP this key to a password manager (1Password, Bitwarden, etc.).
# Generate for NEW deployments:  openssl rand -hex 32
# For REPROVISIONING: RESTORE from the old server's .env backup.
# Do NOT regenerate -- existing encrypted keys will become unreadable.
BYOK_ENCRYPTION_KEY=

# --- Operator Claude Code subscription OAuth (feat-operator-cc-oauth) ---
# Kill-switch for the operator-only `oauth_token` credential (a Claude Code
# subscription token from `claude setup-token`). Default OFF — the entire
# feature is inert (no settings toggle; /api/keys 403s oauth_token writes;
# the lease never reads the oauth row). Only "1"/"true" is truthy.
# Set to "1" ONLY on/after 2026-06-15 (the CLO-gated effective date; the
# lease enforces the date independently). Combine with ADMIN_USER_IDS — the
# operator account whose user_id is listed there is the only one permitted
# to store/use an oauth_token credential.
CC_OAUTH_ENABLED=0

# --- Sentry ---
# Error tracking and CSP violation reporting. New DE org (post-Branch-C):
# org slug `jikigai-eu`, project `web-platform`, ingest cluster `*.ingest.de.sentry.io`,
# API + dashboard host `jikigai-eu.sentry.io` (org-subdomain — NOT `eu.sentry.io`,
# which rewrites slugs ending in `-eu` per learning
# `2026-05-17-sentry-eu-region-host-rewrites-slugs-with-eu-suffix.md`).
#
# SENTRY_DSN is server-side only; NEXT_PUBLIC_SENTRY_DSN is baked into the
# Docker image at build time via ARG directive for client-side error capture.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_CSP_REPORT_URI is the report-uri for CSP violations (constructed from DSN).
# Format: https://o<ORG_ID>.ingest.de.sentry.io/api/<PROJECT_ID>/security/?sentry_key=<PUBLIC_KEY>
# SENTRY_CSP_REPORT_URI=
# Auth token for sentry-cli (source-map upload) + audit-script (CI probes).
# Internal-integration token from jikigai-eu.sentry.io/settings/developer-settings/.
# Scopes: project:read, project:write, project:releases, org:read.
SENTRY_AUTH_TOKEN=
SENTRY_API_TOKEN=
# SENTRY_ISSUE_RW_TOKEN: Internal Integration token used ONLY by
# /soleur:postmerge to auto-resolve a linked Sentry issue when the error
# stopped firing post-deploy. Mint scopes: event:admin (+ org:read, project:read).
# Minted in the jikigai-eu org developer-settings UI; NOT Terraformed (the
# provider exposes no token resource). Doppler soleur/prd.
SENTRY_ISSUE_RW_TOKEN=
# Org + project slugs (used by sentry-cli build args + audit script).
SENTRY_ORG=jikigai-eu
SENTRY_PROJECT=web-platform
# API base for org-scoped REST calls — MUST be the org-subdomain, NOT `eu.sentry.io`
# (which rewrites slugs ending in `-eu` to the literal `eu` org).
SENTRY_API_HOST=jikigai-eu.sentry.io
# sentry-cli base URL (source-map upload target).
SENTRY_URL=https://jikigai-eu.sentry.io/
# DSN-derived cron-checkin triple (read by scheduled-*.yml workflows).
SENTRY_INGEST_DOMAIN=
SENTRY_PROJECT_ID=
SENTRY_PUBLIC_KEY=

# --- Resend ---
# Outbound transactional email (server/notifications.ts throws without it)
# + inbound email-triage ingress (feat-operator-inbox-delegation). Backfill:
# this key was load-bearing but absent from .env.example until Phase 6.
# Full-access API key from resend.com/api-keys. Present in Doppler soleur/prd.
RESEND_API_KEY=
# Svix signing secret for the email.received inbound webhook
# (/api/webhooks/resend-inbound). Minted by the PRE-MERGE run of
# infra/resend-inbound-bootstrap.sh, which writes it straight into Doppler —
# whsec_-prefixed; never paste it into a terminal or commit it.
RESEND_INBOUND_WEBHOOK_SECRET=
# Supabase auth user id (uuid) of the operator who owns triaged inbound
# email rows. email-on-received refuses to claim rows while unset (retriable
# throw — Inngest redelivery means no email is dropped while ops fixes it).
EMAIL_TRIAGE_OWNER_USER_ID=

# --- OAuth Providers (optional) ---
# Enable by setting both client ID and secret for each provider.
# Credentials are configured in each provider's developer console
# and stored in Doppler (production). configure-auth.sh enables
# providers when both values are set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Plugin Stats ---
# Agent count displayed in the connect-repo page. Computed automatically
# by CI from plugins/soleur/agents/**/*.md. For local dev, generate with:
#   find ../../plugins/soleur/agents -name "*.md" | wc -l
# NEXT_PUBLIC_AGENT_COUNT=63

# --- Buttondown (waitlist) ---
# Authenticated REST API key for the marketing waitlist relay (/api/waitlist →
# api.buttondown.com/v1/subscribers). Token-format key from
# buttondown.com/settings/api. Without it, /api/waitlist fails closed to a
# graceful JSON 502 (the worker never crashes). Present in Doppler soleur/prd.
BUTTONDOWN_API_KEY=

# --- Runtime Feature Flags ---
# Each FLAG_* mirrors its prd-segment Flagsmith state (env-var fallback path —
# applies when Flagsmith is unreachable). Only "1" is truthy. See ADR-038 v2
# for the full model (env vs runtime, per-role segmentation, skill contract).
# Leave FLAGSMITH_ENVIRONMENT_KEY empty for env-only local dev (no Flagsmith RTT).
# The management API key lives in operator-only Doppler config `cli`, never here.
FLAGSMITH_ENVIRONMENT_KEY=
# FLAGSMITH_API_URL=https://edge.api.flagsmith.com/api/v1/    # override for self-host
FLAGSMITH_CACHE_MAX_ENTRIES=1000
FLAG_KB_CHAT_SIDEBAR=0
FLAG_TEAM_WORKSPACE_INVITE=0
FLAG_BYOK_DELEGATIONS=0
FLAG_C4_VISUALIZER=0
FLAG_DEBUG_MODE=0
# Gates ONLY the user-direct C4 edit surface (PUT /api/kb/c4 + Code panel UI).
# Default OFF; the =0 mirror is the fail-closed Flagsmith-outage fallback.
FLAG_C4_EDIT=0

# --- Dev-only — DO NOT SET IN PRD ---
# Enables the multi-account QA sign-in panel on /login (R3 / feat-dev-
# signin-bypass). The panel + POST /api/auth/dev-signin route are gated
# by NODE_ENV === "development" AND FLAG_DEV_SIGNIN === "1" — both must
# hold or the surface returns null/404. `verify-required-secrets.sh`
# exits non-zero in CI's prd run if any of the four keys below are
# present in Doppler `prd`. The `assert-dev-signin-eliminated.sh` post-
# build gate flags any forbidden-token leak into client bundles.
#
# Operator runbook (set via separate terminal — never via the `! `
# Claude Code prefix per hr-never-paste-secrets-via-bang-prefix):
#   doppler secrets set FLAG_DEV_SIGNIN=1                -p soleur -c dev
#   doppler secrets set DEV_USER_1_PASSWORD=$(openssl rand -hex 16) -p soleur -c dev
#   doppler secrets set DEV_USER_2_PASSWORD=$(openssl rand -hex 16) -p soleur -c dev
#   doppler secrets set DEV_USER_3_PASSWORD=$(openssl rand -hex 16) -p soleur -c dev
#   doppler run -p soleur -c dev -- bash apps/web-platform/scripts/seed-dev-users.sh
FLAG_DEV_SIGNIN=0
DEV_USER_1_PASSWORD=
DEV_USER_2_PASSWORD=
DEV_USER_3_PASSWORD=

# --- Command Center cost caps (cc-soleur-go runner) ---
# Per-workflow cost ceiling (USD). Breached cumulative `total_cost_usd`
# fires `workflow_ended { status: "cost_ceiling" }` and closes the SDK Query.
# Values recalibrated 2026-04-24 from stream-input rerun data; CFO gate at
# Stage 6.5.1 before merge.
CC_MAX_COST_USD_BRAINSTORM=5.00
CC_MAX_COST_USD_WORK=2.00
CC_MAX_COST_USD_DEFAULT=2.00
# Daily caps (kill switch). Enforcement wires into ws-handler in Stage 2.13.
CC_USER_DAILY_USD_CAP=25.00
CC_GLOBAL_DAILY_USD_CAP=500.00

# --- cc-soleur-go router MCP tool allowlist (#2909) ---
# Comma-separated list of platform tool short-names (e.g. "kb_share_list,github_read_ci_status").
# Default (unset/empty) preserves the deny-by-default posture: no in-process MCP tools
# registered for router-dispatched skills. Phase 1 (this PR) only enforces the Tier 3
# denylist — the 3 Plausible tools (plausible_create_site / plausible_add_goal /
# plausible_get_stats) share a single backend PLAUSIBLE_API_KEY and are PERMANENTLY
# blocked. Full unknown-name validation + actual tool registration lives in Phase 2
# (#3722, blocked-by Stage 6 #2939). NEVER include plausible_* short-names — the
# factory throws at conversation start.
# CC_MCP_ALLOWLIST=

# --- Playwright dev origins (PR-A #2939) ---
# Comma-separated extra origins accepted by lib/auth/validate-origin.ts in
# development mode (NODE_ENV=development). Playwright projects spin up dev
# servers on ports 3099 + 3100 simultaneously; without this list, CSRF
# validation rejects one of them. NEVER set in production — the value is
# ignored when NODE_ENV !== "development".
# NEXT_PUBLIC_DEV_EXTRA_ORIGINS=http://localhost:3099,http://localhost:3100

# --- Optional ---
# PORT=3000
# WORKSPACES_ROOT=/workspaces
# SOLEUR_PLUGIN_PATH=/app/shared/plugins/soleur
# Comma-separated repo-URL substrings (owner/repo slugs) the push-reconcile
# Inngest function skips silently — repos the GitHub App is installed on but
# that are NOT customer workspaces (e.g. Soleur's own dev repo). Matched as exact
# owner/repo equality; defaults to "jikig-ai/soleur" when unset (#4666).
# WORKSPACE_RECONCILE_IGNORE_REPOS=jikig-ai/soleur

# Staleness floor (days) for the KB-sync went-quiet detector (#4717): a
# ready+installed workspace whose default branch has commits but no successful
# sync in this many days is reported to Sentry (op:went-quiet). Defaults to 3
# when unset; a blank or non-positive value falls back to 3 (never 0).
# KB_WENT_QUIET_MAX_GAP_DAYS=3

# Fail-closed Bearer secret for POST /api/internal/trigger-cron (#4734): a
# generated 64-hex random, TF-provisioned in Doppler dev+prd via
# apps/web-platform/infra/inngest.tf (NOT operator-minted). Authenticates
# on-demand dispatch of allowlisted cron/<name>.manual-trigger events. When
# unset the route fail-closes with 503. Doppler-only; left commented here.
# INNGEST_MANUAL_TRIGGER_SECRET=

# feat-stream-since-disconnect (#5273) — in-memory per-conversation WS replay
# buffer (ADR-059). All have safe in-code defaults; override only to tune the
# single-backend-instance memory bound. No Doppler provisioning required.
# Per-conversation ring cap (frame count). Default 2000.
# STREAM_REPLAY_BUFFER_MAX_FRAMES=2000
# Global cap on distinct conversation buffers (LRU-evict oldest). Default 500.
# STREAM_REPLAY_BUFFER_MAX_CONVERSATIONS=500
# Per-conversation byte cap (cumulative stream snapshots). Default 1000000 (~1MB).
# STREAM_REPLAY_BUFFER_MAX_BYTES=1000000
# Idle-conversation TTL backstop (ms), swept amortized on write. Default 45000
# (DISCONNECT_GRACE_MS 30s + 15s margin).
# STREAM_REPLAY_BUFFER_TTL_MS=45000
