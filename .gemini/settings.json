{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "transport": "http"
    },
    "cloudflare": {
      "url": "https://mcp.cloudflare.com/mcp",
      "transport": "http"
    },
    "vercel": {
      "url": "https://mcp.vercel.com",
      "transport": "http"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--isolated"],
      "transport": "stdio"
    }
  }
}
