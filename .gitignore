# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

.DS_Store
*.log
node_modules/
__pycache__/
*.pyc
.codex/
.worktrees
.claude/settings.local.json
.mcp.local.json
.claude/soleur-welcomed.local
.claude/ralph-loop.*.local.md
.claude/.rule-incidents.jsonl
.claude/.rule-incidents-*.jsonl.gz
.claude/.skill-invocations.jsonl
.claude/.skill-invocations-*.jsonl.gz
# Stray Claude Code subagent worktree markers — must never be committed (#2905)
/.claude/worktrees/
.playwright-mcp/
.env
_site/
_site_test/
screenshot-gate-failures/

# Local state (since-id, caches -- do not commit)
.soleur/

# Article 30 register (private -- do not commit)
article-30-register*.md
knowledge-base/private/

# Screenshot and video artifacts (browser tests, feature demos, image generation)
*.png
tmp/

# Legitimate image assets (negate the blanket *.png rule)
!plugins/soleur/docs/images/*.png
!plugins/soleur/docs/images/blog/*.png
!plugins/soleur/docs/screenshots/*.png
!apps/web-platform/public/icons/*.png
!knowledge-base/product/design/**/screenshots/*.png
!knowledge-base/product/design/brand/**/*.png
!knowledge-base/engineering/ops/runbooks/screenshots/**/*.png
!knowledge-base/settings/team-icons/*.png
!knowledge-base/settings/team-icons/*.svg
!knowledge-base/settings/team-icons/*.webp
apps/web-platform/supabase/.temp/

# Ephemeral capture scripts (sdk-probe)
apps/web-platform/scripts/capture-*
artifacts/

# Stage 0 spike throwaway workspace + raw-run artifacts
.spike-workspace/
knowledge-base/project/plans/spike-raw-*.json

# CI-vendored plugin tree (#3045) — populated by reusable-release.yml's
# "Vendor plugin into build context" step before docker build. Local devs
# building the image manually run the same `cp -r` command; never commit.
apps/web-platform/_plugin-vendored/

# Mutation testing report directories (#3121 / #3130). Allowlisted in
# .gitleaks.toml as a defense-in-depth in case a report ever lands by
# accident — but the primary control is this gitignore.
reports/mutation/
.stryker-tmp/
mutants/
