name: fix-constraints-stage-a

# Stage A — UNTRUSTED producer of the two-stage constraint-gate recovery (ADR-074, #5814).
# GENERATED by `plugins/soleur/skills/constraint-scaffold` into __TARGET_DIR__'s CI. The agent
# — never the founder — owns this file and gate maintenance. Runs on `pull_request` — NOT the
# privileged issue_comment / pull-request-target trigger — holds NO write token, and treats
# running PR-head code as
# the EXPECTED, safe thing (`pull_request` is CodeQL's designated untrusted context). If the
# L1 constraint-gate is red on a same-repo PR, it dispatches the agent to FIX it (fix-only —
# never grows the suppression baseline), re-verifies the gate is green, and uploads the fix
# as a full-post-image-contents artifact (per-file sha256 + meta.json) for the privileged
# Stage B (fix-constraints-stage-b, workflow_run) to apply. No commit, no push, no repo-write
# scope here.
#
# SECURITY: `permissions: contents: read` ONLY. The write capability lives exclusively in
# Stage B, which never executes this untrusted tree (Git Data API, no checkout/no apply). The
# name: field above is load-bearing — Stage B's `on: workflow_run: workflows:` matches it by
# NAME, not by filename; a rename here silently stops recovery. Manual retry: re-run this
# workflow (workflow_dispatch) or push a commit to the PR.

on:
  pull_request:
    types: [opened, synchronize, reopened]
    paths:
      - '__TARGET_DIR__/app/**'
      - '__TARGET_DIR__/components/**'
      - '__TARGET_DIR__/server/**'
      - '__TARGET_DIR__/.dependency-cruiser.cjs'
      - '__TARGET_DIR__/.dependency-cruiser-known-violations.json'
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  # One agent dispatch per head SHA — a push-storm on one PR can't fan out N paid runs.
  group: fix-constraints-a-${{ github.event.pull_request.head.sha || github.sha }}
  cancel-in-progress: true

jobs:
  produce:
    # Loop guard: Stage B opens `soleur/fix-constraints/<pr>` follow-up PRs; those must never
    # re-dispatch Stage A (github.head_ref is empty on workflow_dispatch → guard passes).
    if: >-
      github.event_name == 'workflow_dispatch' ||
      !startsWith(github.head_ref, 'soleur/fix-constraints/')
    runs-on: ubuntu-latest
    timeout-minutes: 30
    permissions:
      contents: read
    steps:
      - name: Checkout the PR head (immutable SHA)
        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4.3.1
        with:
          # pull_request checks out the ephemeral merge ref by default; pin to the immutable
          # head SHA so the tree the gate runs on == the tree Stage B attests via head_sha.
          ref: ${{ github.event.pull_request.head.sha }}
          persist-credentials: false

      - name: Anthropic preflight
        id: preflight
        # EXITS 1 (red) when ANTHROPIC_API_KEY is absent (e.g. fork PRs get no secrets);
        # continue-on-error so a keyless run skips the agent instead of failing the job.
        continue-on-error: true
        uses: ./.github/actions/anthropic-preflight
        with:
          anthropic-api-key: ${{ secrets.ANTHROPIC_API_KEY }}

      - name: Setup Bun                          # the gate's depcruise binary lives in node_modules
        uses: oven-sh/setup-bun@3d267786b128fe76c2f16a390aa2448b815359f3 # v2.1.2
        with:
          bun-version-file: ".bun-version"

      - name: Install dependencies (no postinstall scripts over untrusted PR code)
        working-directory: __TARGET_DIR__
        # --ignore-scripts kills the postinstall ACE vector on fork-controlled package.json.
        # (It does NOT stop the gate's own .dependency-cruiser.cjs from running — that is the
        # accepted Stage-A residual, bounded by the capped/rotatable key + no write token.)
        run: bun install --frozen-lockfile --ignore-scripts

      - name: Run the constraint-gate (capture rc)
        id: gate
        run: |
          set +e
          bash __TARGET_DIR__/scripts/constraint-gates.sh
          echo "rc=$?" >> "$GITHUB_OUTPUT"

      - name: Dispatch agent to fix the gate (fix-only)
        if: steps.gate.outputs.rc != '0' && steps.preflight.outputs.ok == 'true'
        id: agent
        uses: anthropics/claude-code-action@ab8b1e6471c519c585ba17e8ecaccc9d83043541 # v1.0.101
        with:
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          # Model pin + action SHA mirror claude-code-review.yml verbatim (CI-validated).
          # Pin freshness is model-launch-review's job — do NOT substitute a model id from memory.
          claude_args: '--model claude-sonnet-4-6 --max-turns 20 --allowedTools Bash,Read,Write,Edit,Glob,Grep'
          prompt: |
            A constraint-gate tripped on this PR. Run `__TARGET_DIR__/scripts/constraint-gates.sh`,
            read the failure, and FIX the offending import so a client ("use client") module no longer
            value-imports the server-only tree (server/**). Make file edits ONLY under
            __TARGET_DIR__/{app,components,server}.
            You are FIX-ONLY: do NOT run the constraint-scaffold generator, do NOT pass
            --refresh-baseline, and do NOT edit .dependency-cruiser-known-violations.json — growing
            the suppression baseline would whitelist a real client->server-secret leak and is a
            maintainer-only local action, never an auto-recovery path.
            If the failure is not a real leak you can fix with an import change, make NO edits.
            Do NOT commit or push — the workflow owns delivery.

      - name: Re-run the gate to VERIFY the fix
        # Assert the invariant — never trust "agent exited 0" (it exits 0 even on give-up).
        if: steps.agent.outcome == 'success'
        id: verify
        run: |
          set +e
          bash __TARGET_DIR__/scripts/constraint-gates.sh
          echo "rc=$?" >> "$GITHUB_OUTPUT"
          if git diff --quiet; then
            echo "changed=false" >> "$GITHUB_OUTPUT"
          else
            echo "changed=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Build recovery artifact (full post-image contents + per-file sha256 + meta.json)
        # Only when the agent produced a real, verified-green change. FIX-ONLY + in-scope:
        # any changed path outside __TARGET_DIR__/{app,components,server} (incl. the baseline
        # JSON, constraint-gates.sh, .github/**, *.cjs) ABORTS the artifact — baseline growth is
        # maintainer-only; auto-recovery never ships an out-of-scope edit.
        if: steps.verify.outputs.rc == '0' && steps.verify.outputs.changed == 'true'
        id: artifact
        env:
          PR_NUMBER: ${{ github.event.pull_request.number }}
          HEAD_SHA: ${{ github.event.pull_request.head.sha }}
          HEAD_REF: ${{ github.event.pull_request.head.ref }}
        run: |
          set -euo pipefail
          staging="${RUNNER_TEMP}/fix-constraints-patch"
          rm -rf "$staging"; mkdir -p "$staging/files"
          # NUL-delimited so any filename survives; post-image (working-tree) contents.
          mapfile -d '' changed < <(git diff --name-only -z)
          if [ "${#changed[@]}" -eq 0 ]; then
            echo "::notice::no changed files — nothing to deliver"; exit 0
          fi
          allow_re='^__TARGET_DIR__/(app|components|server)/'
          files_json='[]'
          for f in "${changed[@]}"; do
            if [[ ! "$f" =~ $allow_re ]]; then
              echo "::error::agent edited an out-of-scope path (${f}) — auto-recovery is fix-only and in-scope-only; no artifact produced. A maintainer must review."
              exit 0   # no artifact => Stage B no-ops; the give-up IS the feedback
            fi
            dest="$staging/files/$f"
            mkdir -p "$(dirname "$dest")"
            cp "$f" "$dest"
            sha="$(sha256sum "$f" | awk '{print $1}')"
            files_json="$(jq -c --arg p "$f" --arg s "$sha" '. + [{path:$p, sha256:$s}]' <<<"$files_json")"
          done
          jq -n --arg pr "$PR_NUMBER" --arg sha "$HEAD_SHA" --arg ref "$HEAD_REF" \
                --argjson files "$files_json" \
            '{pr_number: ($pr|tonumber), head_sha: $sha, head_ref: $ref, files: $files, touches_baseline: false}' \
            > "$staging/meta.json"
          echo "dir=${staging}" >> "$GITHUB_OUTPUT"
          echo "produced=true" >> "$GITHUB_OUTPUT"

      - name: Upload recovery artifact
        if: steps.artifact.outputs.produced == 'true'
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: fix-constraints-patch-${{ github.event.pull_request.number }}
          path: ${{ steps.artifact.outputs.dir }}
          retention-days: 1
          if-no-files-found: error
