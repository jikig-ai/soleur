<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header class="site-header">
    <a href="/" class="logo">
      <div class="header-mark">S</div>
      <span class="header-name">{{ site.name }}</span>
    </a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true">
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle navigation">&#9776;</label>
    <ul class="nav-links">
      {%- for item in site.nav %}
      <li><a href="{{ item.url }}"{% if page.url == ('/' + item.url) or (item.url == 'blog/' and page.url.startsWith('/blog')) %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
      {%- endfor %}
      {%- if site.primaryCta %}
      <li class="nav-cta-slot"><a href="{{ site.primaryCta.url }}" aria-label="{{ site.primaryCta.ariaLabel }}" class="btn btn-primary btn--sm nav-cta">{{ site.primaryCta.label }}</a></li>
      {%- endif %}
    </ul>
  </header>

  <main id="main-content"{% if mainClass %} class="{{ mainClass }}"{% endif %}>
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  {% set location = "footer" %}
  {% include "newsletter-form.njk" %}

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <div class="footer-mark">S</div>
            <span class="footer-name">{{ site.name }}</span>
          </div>
          <p class="footer-tagline">Designed, built, and shipped by {{ site.name }} &mdash; using {{ site.name }}.</p>
          <div class="footer-social">
            <a href="{{ site.discord }}" target="_blank" rel="noopener" aria-label="Discord">Discord</a>
            <a href="{{ site.github }}" target="_blank" rel="noopener" aria-label="GitHub">GitHub</a>
            <a href="{{ site.x }}" target="_blank" rel="noopener" aria-label="X / Twitter">X</a>
            <a href="{{ site.linkedinCompany }}" target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a>
            <a href="{{ site.bluesky }}" target="_blank" rel="noopener" aria-label="Bluesky">Bluesky</a>
          </div>
        </div>
        {%- for col in site.footerColumns %}
        <div class="footer-col">
          <h3 class="footer-heading">{{ col.heading }}</h3>
          <ul class="footer-links">
            {%- for link in col.links %}
            <li><a href="{{ link.url }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}{% if link.title %} title="{{ link.title }}"{% endif %}>{{ link.label }}</a></li>
            {%- endfor %}
          </ul>
        </div>
        {%- endfor %}
      </div>
      <div class="footer-bottom">
        <ul class="footer-legal">
          {%- for link in site.footerLegal %}
          <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {%- endfor %}
        </ul>
        <span class="footer-copyright">&copy; {{ site.name }} 2026</span>
      </div>
    </div>
  </footer>

  <!-- CSP: editing this script requires updating the sha256 hash in the CSP meta tag above. Run validate-csp.sh to check. -->
  <script>
  function handleSignupForm(form, opts) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var honeypot = form.querySelector('input[name="url"]');
      if (honeypot && honeypot.value) return;
      var btn = form.querySelector('button[type="submit"]');
      var status = form.querySelector('.newsletter-status');
      btn.disabled = true;
      fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form))
      }).then(function(res) {
        if (res.ok) {
          status.textContent = opts.successMessage;
          status.className = 'newsletter-status newsletter-success';
          form.querySelector('input[type="email"]').value = '';
          if (window.plausible) plausible(opts.event, { props: opts.props(form) });
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'newsletter-status newsletter-error';
        }
      }).catch(function() {
        status.textContent = 'Something went wrong. Please try again.';
        status.className = 'newsletter-status newsletter-error';
      }).finally(function() {
        btn.disabled = false;
      });
    });
  }

  document.querySelectorAll('.newsletter-form:not(.waitlist-form):not(.hero-waitlist-form)').forEach(function(form) {
    handleSignupForm(form, {
      successMessage: 'Subscribed. You will hear from us when it matters.',
      event: 'Newsletter Signup',
      props: function(f) { return { location: f.id.replace('newsletter-', '') }; }
    });
  });

  document.querySelectorAll('.waitlist-form').forEach(function(form) {
    handleSignupForm(form, {
      successMessage: 'You are on the list. We will notify you when the cloud platform is ready.',
      event: 'Waitlist Signup',
      props: function(f) {
        var tier = f.querySelector('input[name="metadata__tier_interest"]');
        return { location: 'pricing-waitlist', tier: tier ? tier.value : 'unknown' };
      }
    });
  });

  document.querySelectorAll('.hero-waitlist-form').forEach(function(form) {
    handleSignupForm(form, {
      successMessage: 'You are on the list. We will notify you when the cloud platform is ready.',
      event: 'Waitlist Signup',
      props: function(f) { return { location: 'homepage-hero' }; }
    });
  });
  </script>
</body>
</html>
