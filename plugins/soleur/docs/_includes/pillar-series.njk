{% set currentPillar = pillars[pillar] %}
{% if pillar and not currentPillar %}<!-- pillar-series: unknown key "{{ pillar }}" in _data/pillars.js -->{% endif %}
{% if currentPillar %}
<aside class="pillar-series" aria-label="Part of the {{ currentPillar.title }} series">
  <p class="pillar-series__label">Part of the <strong>{{ currentPillar.title }}</strong> series:</p>
  <ul class="pillar-series__list">
    {%- for member in currentPillar.members %}
    <li>
      {%- if member.url == page.url %}
      <span class="pillar-series__current">
        {%- for p in collections.blog -%}{%- if p.url == member.url -%}{{ p.data.title }}{%- endif -%}{%- endfor %} (you are here)</span>
      {%- else %}
      <a href="{{ member.url }}">
        {%- for p in collections.blog -%}{%- if p.url == member.url -%}{{ p.data.title }}{%- endif -%}{%- endfor -%}
      </a>{% if member.relation == "pillar" %} — pillar{% endif %}
      {%- endif %}
    </li>
    {%- endfor %}
  </ul>
</aside>
{% endif %}
