---
layout: base.njk
---
{% block extraHead %}
<meta property="article:published_time" content="{{ date | dateToRfc3339 }}" />
{% for tag in tags %}{% if tag != "blog" %}
<meta property="article:tag" content="{{ tag }}" />
{% endif %}{% endfor %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "datePublished": "{{ date | dateToRfc3339 }}",
  "dateModified": "{{ updated | dateToRfc3339 if updated else date | dateToRfc3339 }}",
  "url": "{{ site.url }}{{ page.url }}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  },
  "inLanguage": "en-US",
  "image": "{{ site.url }}/images/og-image.png",
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.author.url }}",
    "jobTitle": "{{ site.author.role }} of {{ site.name }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/images/logo-mark-512.png",
      "width": 512,
      "height": 512
    }
  }
}
</script>
{% endblock %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1>{{ title }}</h1>
    <p class="subtitle">{{ description }}</p>
    <div class="blog-post-meta">
      <time datetime="{{ date | dateToRfc3339 }}">{{ date | readableDate }}</time>
      {% if updated %}
      <span class="blog-post-updated">Updated <time datetime="{{ updated | dateToRfc3339 }}">{{ updated | readableDate }}</time></span>
      {% endif %}
      <span class="blog-post-author">by <a href="{{ site.author.url }}" rel="author">{{ site.author.name }}</a>, {{ site.author.role }} of {{ site.name }}</span>
    </div>
    {% if tags %}
    <div class="blog-tags">
      {% for tag in tags %}{% if tag != "blog" %}
      <span class="blog-tag-chip">{{ tag }}</span>
      {% endif %}{% endfor %}
    </div>
    {% endif %}
  </div>
</section>

<section class="content">
  <div class="container">
    <div class="prose">
      {{ content | safe }}
    </div>
  </div>
</section>
{% endblock %}
