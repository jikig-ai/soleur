---
layout: base.njk
---
{% block extraHead %}
<meta property="article:published_time" content="{{ date | dateToRfc3339 }}" />
{% for tag in tags %}{% if tag != "blog" %}
<meta property="article:tag" content="{{ tag }}" />
{% endif %}{% endfor %}
<script type="application/ld+json">
{# All string interpolations in this JSON-LD block MUST use | dump | safe — see #2609 #}
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": {{ (date | dateToRfc3339) | dump | safe }},
  "dateModified": {{ (updated | dateToRfc3339 if updated else date | dateToRfc3339) | dump | safe }},
  "url": {{ (site.url + page.url) | dump | safe }},
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ (site.url + page.url) | dump | safe }}
  },
  "inLanguage": "en-US",
  "image": {{ (site.url + "/images/og-image.png") | dump | safe }},
  "author": {
    "@type": "Person",
    "name": {{ site.author.name | dump | safe }},
    "url": {{ site.author.url | dump | safe }},
    "jobTitle": {{ (site.author.role + " of " + site.name) | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ (site.url + "/images/logo-mark-512.png") | dump | safe }},
      "width": 512,
      "height": 512
    }
  }
}
</script>
{% endblock %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1>{{ title }}</h1>
    <p class="subtitle">{{ description }}</p>
    <div class="blog-post-meta">
      <time datetime="{{ date | dateToRfc3339 }}">{{ date | readableDate }}</time>
      {% if updated %}
      <span class="blog-post-updated">Updated <time datetime="{{ updated | dateToRfc3339 }}">{{ updated | readableDate }}</time></span>
      {% endif %}
      <span class="blog-post-author">by <a href="{{ site.author.url }}" rel="author">{{ site.author.name }}</a>, {{ site.author.role }} of {{ site.name }}</span>
    </div>
    {% if tags %}
    <div class="blog-tags">
      {% for tag in tags %}{% if tag != "blog" %}
      <span class="blog-tag-chip">{{ tag }}</span>
      {% endif %}{% endfor %}
    </div>
    {% endif %}
  </div>
</section>

<section class="content">
  <div class="container">
    <div class="prose">
      {{ content | safe }}
    </div>
  </div>
</section>
{% endblock %}
