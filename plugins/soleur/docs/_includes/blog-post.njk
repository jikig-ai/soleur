---
layout: base.njk
---
{% block extraHead %}
<meta property="article:published_time" content="{{ date | dateToRfc3339 }}" />
{% if updated %}<meta property="article:modified_time" content="{{ updated | dateToRfc3339 }}" />
{% endif %}<meta property="article:author" content="{{ site.author.url }}" />
{% for tag in tags %}{% if tag != "blog" %}
<meta property="article:tag" content="{{ tag }}" />
{% endif %}{% endfor %}
<script type="application/ld+json">
{# All string interpolations in this JSON-LD block MUST use | jsonLdSafe | safe — see #2609 #}
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | jsonLdSafe | safe }},
  "description": {{ description | jsonLdSafe | safe }},
  "datePublished": {{ (date | dateToRfc3339) | jsonLdSafe | safe }},
  "dateModified": {{ (updated | dateToRfc3339 if updated else date | dateToRfc3339) | jsonLdSafe | safe }},
  "url": {{ (site.url + page.url) | jsonLdSafe | safe }},
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ (site.url + page.url) | jsonLdSafe | safe }}
  },
  "inLanguage": "en-US",
  "image": {{ (site.url + "/images/" + (ogImage if ogImage else "og-image.png")) | jsonLdSafe | safe }},
  "author": {
    "@type": "Person",
    "@id": {{ (site.url + "/about/#jean-deruelle") | jsonLdSafe | safe }},
    "name": {{ site.author.name | jsonLdSafe | safe }},
    "url": {{ site.author.url | jsonLdSafe | safe }},
    "jobTitle": {{ (site.author.role + " of " + site.name) | jsonLdSafe | safe }},
    "description": {{ site.author.bio | jsonLdSafe | safe }},
    "image": {{ (site.url + site.author.image) | jsonLdSafe | safe }},
    "sameAs": {{ site.author.sameAs | jsonLdSafe | safe }},
    "knowsAbout": {{ site.author.knowsAbout | jsonLdSafe | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | jsonLdSafe | safe }},
    "url": {{ site.url | jsonLdSafe | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ (site.url + "/images/logo-mark-512.png") | jsonLdSafe | safe }},
      "width": 512,
      "height": 512
    }
  }
}
</script>
{% endblock %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1>{{ title }}</h1>
    <p class="subtitle">{{ description }}</p>
    <div class="blog-post-meta">
      <time datetime="{{ date | dateToRfc3339 }}">{{ date | readableDate }}</time>
      {% if updated %}
      <span class="blog-post-updated">Updated <time datetime="{{ updated | dateToRfc3339 }}">{{ updated | readableDate }}</time></span>
      {% endif %}
      <span class="blog-post-author">by <a href="{{ site.author.url }}" rel="author">{{ site.author.name }}</a>, {{ site.author.role }} of {{ site.name }}</span>
    </div>
    {% if tags %}
    <div class="blog-tags">
      {% for tag in tags %}{% if tag != "blog" %}
      <span class="blog-tag-chip">{{ tag }}</span>
      {% endif %}{% endfor %}
    </div>
    {% endif %}
  </div>
</section>

<section class="content">
  <div class="container">
    {# pillar-series guards internally on pillars[pillar] — no outer {% if pillar %} needed. #}
    {% include "pillar-series.njk" %}
    <div class="prose">
      {{ content | safe }}
    </div>
  </div>
</section>

<section class="author-card-section" aria-label="About the author">
  <div class="container">
    <div class="author-card">
      <img class="author-card-photo"
           src="{{ site.author.image }}"
           width="96"
           height="96"
           alt="{{ site.author.name }} — {{ site.author.role }} of {{ site.name }}"
           loading="lazy"
           decoding="async">
      <div class="author-card-body">
        <p class="author-card-name">{{ site.author.name }}</p>
        <p class="author-card-role">{{ site.author.role }} of {{ site.name }}</p>
        <p class="author-card-bio">{{ site.author.bio }}</p>
        {% if site.author.credentials %}
        <ul class="author-card-credentials">
          {% for credential in site.author.credentials %}
          <li>{{ credential }}</li>
          {% endfor %}
        </ul>
        {% endif %}
        {% if site.author.sameAs %}
        <ul class="author-card-links">
          {% for link in site.author.sameAs %}
          {% if "github.com" in link %}
          <li><a href="{{ link }}" rel="noopener noreferrer me" target="_blank" aria-label="GitHub"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg></a></li>
          {% elif "x.com" in link or "twitter.com" in link %}
          <li><a href="{{ link }}" rel="noopener noreferrer me" target="_blank" aria-label="X"><svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.933Zm-1.29 19.494h2.039L6.486 3.24H4.298L17.611 20.647Z"/></svg></a></li>
          {% elif "linkedin.com" in link %}
          <li><a href="{{ link }}" rel="noopener noreferrer me" target="_blank" aria-label="LinkedIn"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg></a></li>
          {% else %}
          <li><a href="{{ link }}" rel="noopener noreferrer me" target="_blank">{{ link | replace("https://", "") | replace("www.", "") }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endblock %}
