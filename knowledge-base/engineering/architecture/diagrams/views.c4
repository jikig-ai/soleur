// Soleur architecture — views over the consolidated model (model.c4).
// One view per C4 level. `view <id> of <element>` gives LikeC4 automatic
// clickable drill-down: in the context view the `platform` box drills into
// `containers`; in `containers` the `plugin` box drills into `components`.
views {

  // ---- C4 L1: System Context --------------------------------------------
  view context {
    title "Soleur Platform — System Context (C4 L1)"

    include
      founder, emailSender, betaContact, contributor,
      platform, platform.webapp, platform.engine, platform.infra.supabase,
      anthropic, github, cloudflare, doppler, discord, stripe, plausible, resend, pushService, ghcr, zotRegistry, betterstack, sentry, sigstore, letsencrypt, publicResolvers

    style element.tag == #external {
      color muted
    }
    autoLayout TopBottom
  }

  // ---- C4 L2: Containers (drill-down target of `platform`) --------------
  view containers of platform {
    title "Soleur Platform — Containers (C4 L2)"

    include
      founder, emailSender, betaContact, contributor,
      platform.webapp, platform.engine, platform.plugin, platform.infra,
      platform.webapp.dashboard, platform.webapp.api, platform.webapp.auth,
      platform.engine.claude, platform.engine.skillloader, platform.engine.hooks,
      platform.plugin.skills, platform.plugin.agents, platform.plugin.kb,
      platform.infra.supabase, platform.infra.operationalInbox, platform.infra.crmStore, platform.infra.tunnel, platform.infra.hetzner,
      platform.infra.inngest, platform.infra.inngestPostgres, platform.infra.inngestRedis,
      platform.infra.coordinator, platform.infra.scheduler,
      platform.infra.gitDataStore, platform.infra.sessionStore, platform.infra.workspacesVolume,
      anthropic, github, cloudflare, doppler, stripe, plausible, resend, pushService, ghcr, zotRegistry, betterstack, sentry,
      connectedRepoPlugin

    style element.tag == #external {
      color muted
    }
    autoLayout TopBottom
  }

  // ---- C4 L3: Soleur Plugin components (drill-down target of `plugin`) ---
  view components of platform.plugin {
    title "Soleur Plugin — Components (C4 L3)"

    include
      platform.plugin,
      platform.plugin.go, platform.plugin.sync, platform.plugin.help,
      platform.plugin.brainstorm, platform.plugin.plan, platform.plugin.work,
      platform.plugin.review, platform.plugin.compound, platform.plugin.ship,
      platform.plugin.oneshot, platform.plugin.architecture,
      platform.plugin.cto, platform.plugin.cmo, platform.plugin.cpo,
      platform.plugin.archstrat, platform.plugin.evalharness,
      platform.plugin.constraintscaffold,
      platform.engine.claude, platform.engine.hooks, platform.plugin.kb

    autoLayout LeftRight
  }
}
