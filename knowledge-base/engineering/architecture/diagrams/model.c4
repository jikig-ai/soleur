// Soleur architecture — consolidated C4 model (single source of truth).
// Every element is defined ONCE here; the views in views.c4 scope it to each
// C4 level (context / container / component) with clickable drill-down.
// Migrated 1:1 from the former Mermaid C4 diagrams (system-context, container,
// component-plugin) — union of all elements and relationships, nothing dropped.
model {

  founder = actor "Founder / Operator" {
    description "A workspace Owner using Soleur as their AI organization. Workspaces may have MULTIPLE Owners (ADR-038, ADR-073 team workspaces); Owner-shared surfaces (e.g. the operator email-triage inbox, ADR-066) are readable by every Owner, not just one founder."
  }

  // External actor — third parties whose inbound email is the operator
  // email-triage inbox's source (ADR-066 / mig 102).
  emailSender = actor "Inbound Correspondent" {
    #external
    description "Vendors, regulators, and counsel emailing the operator address. Their statutory/operational mail is the email-triage inbox's inbound source."
  }

  // External actor — an involuntary third-party data subject whose conversation
  // PII the operator captures in the beta-CRM (ADR-102 / mig 126). The operator
  // is the controller; the beta tester never touches the store directly.
  betaContact = actor "Beta Tester / Prospect" {
    #external
    description "A beta tester or prospect the operator is in sales/product conversations with. The origin of the third-party contact + conversation PII captured in the owner-private beta-CRM (beta_contacts / interview_notes). An involuntary data subject (Art. 14); no direct access to the store."
  }

  // External actor — an UNTRUSTED pull-request author, distinct from the trusted
  // `founder` Owner above. Their PR-head code executes only in the fix-constraints
  // Stage A recovery producer (`pull_request`, contents:read, no write/secret
  // token); it never runs in the privileged Stage B consumer (ADR-074).
  contributor = actor "Contributor / PR Author" {
    #external
    description "An untrusted contributor opening a pull request. Their PR-head code is executed only by the fix-constraints Stage A producer (pull_request, contents:read, no write token) — never by the privileged Stage B consumer, which opens a data-only draft follow-up PR from the default branch (ADR-074)."
  }

  // ---- Soleur Platform (enterprise boundary) -----------------------------
  platform = system "Soleur Platform" {

    webapp = system "Web Application" {
      description "Next.js PWA providing dashboard and conversation UI"

      dashboard = container "Dashboard" {
        technology "React, Next.js"
        description "Conversation UI, knowledge base viewer, session management"
        style { shape browser }
      }
      api = container "API Routes" {
        technology "Next.js API"
        description "REST endpoints for auth, sessions, and agent control. Registers in-process Agent-SDK options.hooks (sandbox, subagent-audit, phase-surface, tool-attempt-telemetry, context-queries) on web agent sessions — settingSources:[] isolates these from the CLI .claude/ shell Hook Engine (ADR-070 #5772, #5843; ADR-086 #6046)."
      }
      auth = container "Auth Module" {
        technology "Supabase Auth"
        description "JWT authentication, OAuth providers, session tokens"
      }
    }

    engine = system "Cloud CLI Engine" {
      description "Claude Code instances executing agent workflows"

      claude = container "Agent Runtime" {
        technology "Claude Code"
        description "Executes agent workflows with full orchestration tools"
      }
      skillloader = container "Skill Loader" {
        technology "Plugin Discovery"
        description "Discovers and loads skills, agents, commands from plugin directory"
      }
      hooks = container "Hook Engine" {
        technology "PreToolUse Guards + PostToolUse hints"
        description "Guards tool calls (blocks commits to main, rm -rf, etc.) AND injects additive context — phase-surface hints (ADR-070) and declarative skill context_queries (ADR-086)."
      }
    }

    plugin = system "Soleur Plugin" {
      description "plugins/soleur/ — skills, agents, and knowledge base"

      skills = container "Skills" {
        technology "Markdown SKILL.md"
        description "61 workflow skills — brainstorm, plan, work, review, compound, etc."
      }
      agents = container "Agents" {
        technology "Markdown Agent Defs"
        description "65 domain agents across 8 departments"
      }
      kb = database "Knowledge Base" {
        technology "Markdown + YAML"
        description "Conventions, learnings, ADRs, specs, plans, brainstorms"
      }

      // C4 L3 — components inside the Soleur Plugin
      go = component "go command" {
        technology "Entry Point"
        description "Classifies intent and routes to workflow skills"
      }
      sync = component "sync command" {
        technology "Entry Point"
        description "Populates knowledge-base from existing codebase"
      }
      help = component "help command" {
        technology "Entry Point"
        description "Lists all available commands, skills, and agents"
      }
      brainstorm = component "brainstorm skill" {
        technology "Workflow"
        description "Explores requirements with domain leader assessment"
      }
      plan = component "plan skill" {
        technology "Workflow"
        description "Creates implementation plans with research and domain review"
      }
      work = component "work skill" {
        technology "Workflow"
        description "Executes plans with incremental commits and test-first"
      }
      review = component "review skill" {
        technology "Workflow"
        description "Multi-agent code review with 8 parallel reviewers"
      }
      compound = component "compound skill" {
        technology "Workflow"
        description "Captures learnings and promotes to constitution"
      }
      ship = component "ship skill" {
        technology "Workflow"
        description "Validates artifacts, creates PR, manages merge lifecycle"
      }
      oneshot = component "one-shot skill" {
        technology "Orchestrator"
        description "Full autonomous pipeline: plan, work, review, compound, ship"
      }
      architecture = component "architecture skill" {
        technology "Documentation"
        description "ADR lifecycle and C4 diagram generation"
      }
      cto = component "CTO agent" {
        technology "Domain Leader"
        description "Engineering assessment, architecture decision detection"
      }
      cmo = component "CMO agent" {
        technology "Domain Leader"
        description "Marketing assessment, content opportunities"
      }
      cpo = component "CPO agent" {
        technology "Domain Leader"
        description "Product strategy, UX flow analysis"
      }
      archstrat = component "architecture-strategist" {
        technology "Review Agent"
        description "Architectural compliance and ADR coverage check"
      }
      evalharness = component "eval-harness skill" {
        technology "Validation Gate"
        description "Validation-gates classifier-skill block edits (no-regression + target-passes)"
      }
      constraintscaffold = component "constraint-scaffold skill" {
        technology "Constraint Generator"
        description "Generates the L1 dep-cruiser import-boundary gate (client→server-secret) plus the two-stage pull_request→workflow_run auto-recovery workflows (ADR-074) into the product codebase CI"
      }
    }

    infra = system "Infrastructure" {
      description "Hosting, data, and zero-trust access"

      supabase = database "Supabase PostgreSQL" {
        technology "PostgreSQL"
        description "Users, BYOK-encrypted API keys, conversation sessions"
      }
      operationalInbox = database "Operational Inbox" {
        technology "Supabase (inbox_item, mig 122)"
        description "Severity-ranked operational-notification store (ADR-085, #6007). Mutable read/act/archive state, workspace-grain, Owner-shared reads — SEPARATE from the email-triage WORM statutory ledger. Content-minimized (title + source_ref ids only). GET /api/inbox merges it with email-triage into one severity-ordered feed (statutory pinned first)."
      }
      crmStore = database "Beta-CRM Store" {
        technology "Supabase (beta_contacts, interview_notes, beta_contact_stage_transitions, beta_contact_access_log; mig 126 + 127)"
        description "Owner-private beta-tester / prospect CRM (ADR-102, #6165). Third-party contact PII + dual-lens conversation notes + append-only stage-transition history. Owner-only RLS; writes RPC-only via auth.uid()-pinned SECURITY DEFINER functions; the cro/cpo agents read AND write via the crm_* MCP tools (agent-native parity). 24-month retention; Art. 17 via ON DELETE CASCADE + crm_erase_contact."
      }
      tunnel = container "Cloudflare Tunnel" {
        technology "cloudflared (ONE tunnel; ONE connector live in prod: web-1 — web-2 retired 2026-07-17 (#6538/#6463). The web_tunnel_connector gate is construction-time only)"
        description "Zero-trust inbound access — no exposed ports. ONE tunnel (tunnel.tf) with THREE ingress rules (deploy./ssh./registry.). DETERMINISM IS NOW STRUCTURAL, not one-connector: since #6594/PR-A all three ingress services are ORIGIN-RELATIVE (deploy. → http://10.0.1.10:9000, ssh. → ssh://10.0.1.10:22, registry. → tcp://10.0.1.30:5000), so whichever connector replica CF selects proxies to the correct origin (ADR-114 I2 discharged for all three). This — not 'localhost: means this host' — is what makes the management plane deterministic. NOT AN INVARIANT: the earlier 'exactly ONE connector, ADR-114 I1 enforced #6425' claim is FALSE in production. The server.tf web_tunnel_connector gate lives at cloud-init create-time user_data only, and hcloud_server.web carries ignore_changes=[user_data], so it never re-runs on a booted host. (Historical: web-2 booted 2026-07-13 BEFORE the gate merged 2026-07-15, so TWO connectors were live and measured; web-2 was retired 2026-07-17 (#6538/#6463) and var.web_hosts is now single-host.) I1 is a construction-time gate presented as a runtime precondition — it governs only future fresh hosts, and that stays true after #6441: the NIC gate added there is FIRST-BOOT (runcmd is once-per-instance), so a fresh connector host now waits for its private address before registering and DEFERS rather than aborting on timeout, but no gate re-runs on a host that is already up. CF binds ingress to a TUNNEL and picks a connector per edge colo; before the origin-relative pin a SECOND connector silently made every non-fan-out route (deploy-status, inngest-liveness, infra-config WRITEs, ssh.) answer from whichever replica the caller's colo selected — #6425 (16h of false inngest-down alarms), #6594 (a false-green infra-config apply), #6416. Origin-relative ingress makes that harmless: the coin flip no longer determines correctness. Standing guard: the */15 connector census in scheduled-inngest-health.yml (vantage-independent; a response-poll is colo-sticky and proves nothing). Management plane only: app.soleur.ai does NOT traverse the tunnel (direct CF-proxied A record, dns.tf); no cloudflared on zot/git-data/inngest (ADR-096)."
      }
      hetzner = container "Compute" {
        technology "Hetzner Cloud"
        description "Cluster of Hetzner Cloud hosts (Nomad clients, spread placement) running web app + CLI engine containers. Per-user worktrees are host-local in the ADR-068 §1 sense (they do NOT live on the shared git-data host) but they are NOT on the root NVMe — they sit on a per-host ATTACHED BLOCK VOLUME, workspacesVolume below (#6588 corrected this description, which said 'host-local NVMe' and led readers to conclude there was no volume to encrypt). At first boot a fresh host pulls the web app image from GHCR and extracts its baked bootstrap scripts + hooks.json.tmpl via docker cp (ADR-080, #5921) — a path web-1 can never take: cx33 is unorderable in all 3 EU DCs and lifecycle{ignore_changes=[user_data]} means cloud-init never re-runs, so the bake reaches no live host (ADR-119 §(e))"
      }
      workspacesVolume = database "Workspace Git Data (/workspaces)" {
        technology "Hetzner Cloud block volume — ext4, mounted /mnt/data, bind-mounted into the app container as /workspaces"
        description "Every user's checked-out repository. SOLE-COPY: refs/checkpoints/* is pushed by no refspec, session-sync.ts autocommits only knowledge-base/**, and signup-provisioned workspaces have no git remote at all — so ADR-068 §1's 'GitHub remains the durable rehydration source' does NOT hold here and there is no durable second copy anywhere (no upstream to rehydrate from — the ONLY transient exception is the dead-man divergence window of #6812, when writes briefly existed on the LUKS volume while the app served plaintext). PLAINTEXT AT REST as of 2026-07-21 while the published privacy policy claims LUKS — the gap #6588/ADR-119 closes by cutting over to an additive LUKS volume (blue-green is impossible: cx33 unorderable ⇒ -replace would destroy the sole prod host and fail to recreate it). NOTE the date: a real cutover DID land on 2026-07-20 (run 29782780158) and /mnt/data was genuinely crypto_LUKS on /dev/mapper/workspaces for ~27 minutes — then its own dead-man timer remounted the retained plaintext volume over it and the encryption was silently undone (#6812). The cutover aborted at app_canary on a Cloudflare 521 boot race, which is BEFORE disarm_dead_man, so the backstop was never cleared. Do not read the 2026-07-20 landing as 'encrypted now': the current mount source is the raw /dev/sdb. web-2's instance was knowingly left plaintext (never served, empty) until its 2026-07-17 teardown (#6538/#6463); the fleet is single-host"
      }
      inngest = container "Inngest Server" {
        technology "Dedicated Hetzner host, private-net 10.0.1.40:8288/:8289"
        description "Durable trigger layer for server-side agents — cron, oneshot, and HTTP-armed reminders. Extracted to its own single-host private-net node so exactly-one-scheduler is enforced by topology, unblocking active-active web (ADR-030, ADR-100, #6178)"
      }
      inngestPostgres = database "Supabase PostgreSQL (Inngest)" {
        technology "PostgreSQL — dedicated EU project, Supavisor session pooler :5432"
        description "Inngest config + run history. Dedicated project isolates connection budget + fate from the main app DB (#5450). Public tables RLS-locked; reachable only as the postgres owner (ADR-030 I8)"
      }
      inngestRedis = container "Inngest Redis" {
        technology "Self-hosted Redis — AOF on /mnt/data"
        description "Inngest durable queue + run-state. AOF on the persistent volume survives a host re-provision — the armed-reminder durability fix (#5450)"
      }

      // ---- Multi-host /workspaces cluster (ADR-068, #5274 — adopting) ------
      // Staged Approach A. Live-handle state stays host-local. Phase 3 GA is
      // USER-STICKY (ADR-068 2026-07-01 amendment): a session routes to the host
      // holding that user's per-user worktree lease; control ops are sticky to
      // the owner (NO cross-host forwarding). Redis enters at Phase 4a. GA at P3.
      coordinator = container "Session Router" {
        technology "Node — co-located sticky reverse-proxy"
        description "Co-located stateless sticky router (in each web-host process, not a separate box) — resolves a session's owning host from the per-user worktree lease at the WS-upgrade handshake; local ⇒ serve, remote ⇒ proxy over one-way-TLS private net. Control ops are host-local (no cross-host forwarding). Lease in Postgres (ADR-068 user-sticky amendment)"
      }
      scheduler = container "Nomad Scheduler" {
        technology "Nomad (Phase 4a)"
        description "Placement, health-reschedule, and rolling deploys across the Hetzner cluster (ADR-068 Phase 4a)"
      }
      gitDataStore = database "Shared git-data" {
        technology "Bare git repos over private net"
        description "Shared bare git repos (objects/refs) over the private net; per-user worktrees stay host-local on NVMe. The git-data host holds the per-ref monotonic max generation and writer-side-CAS-rejects stale lease writes (ADR-068)"
      }
      sessionStore = database "Session Redis" {
        technology "Self-hosted Redis — TLS, EU (Phase 4a)"
        description "Self-hosted EU Redis — ADR-059 replay buffer + session/control state; network-reachable, per-workspace key namespacing, TLS + requirepass. DISTINCT node from the loopback Inngest Redis (ADR-068 Phase 4a)"
      }
    }
  }

  // ---- External systems (third-party, outside the platform boundary) ------
  anthropic = system "Anthropic API" {
    #external
    description "Claude LLM for agent reasoning and tool use"
  }
  github = system "GitHub" {
    #external
    description "Source control, CI/CD, issue tracking, and releases"
  }
  cloudflare = system "Cloudflare" {
    #external
    description "DNS, CDN, R2 storage, and zero-trust tunnel"
  }
  doppler = system "Doppler" {
    #external
    description "Centralized secrets management with runtime injection"
  }
  discord = system "Discord" {
    #external
    description "Community notifications and release announcements"
  }
  stripe = system "Stripe" {
    #external
    description "Payment processing and subscription billing"
  }
  plausible = system "Plausible Analytics" {
    #external
    description "Privacy-focused website analytics"
  }
  resend = system "Resend" {
    #external
    description "Inbound email ingress (operator-inbox webhook, svix-verified) + transactional outbound (statutory triage notifications). ADR-066."
  }
  ghcr = system "GitHub Container Registry" {
    #external
    description "PRIVATE GHCR registry (ghcr.io/jikig-ai/soleur-web-platform + soleur-inngest-bootstrap) — the ORIGINAL host pull source, now the DUAL-PUSH + break-glass FALLBACK during the migration to self-hosted zot (ADR-096, #6122); retired from the pull path after the Phase-5 soak (App tokens can't pull GHCR, so it cannot deliver a zero-touch machine credential — ADR-088 superseded). Still bakes the host bootstrap scripts + hooks.json.tmpl, extracted via docker cp at first boot to keep cloud-init user_data under Hetzner's 32,768-byte cap (ADR-080, #5921)."
  }
  zotRegistry = system "Self-hosted zot registry" {
    #selfhosted
    description "OCI-native container registry (zot) on a dedicated Hetzner host (cx33, 4 vCPU / 8 GB, hel1, volume-backed) on the private network (10.0.1.30:5000), behind a deny-all-public firewall — the zero-touch machine-credential registry that replaces GHCR on the pull path (ADR-096, #6122). Sized cx33 in hel1 (#6288 — the plan's cx32 target does not exist as a Hetzner type; cx33 is the real 8 GB type, offered in hel1 not nbg1) with an ADR-062 --memory=7168m cap so zot's ~35 GB store boot scan cannot host-OOM restart-loop the box. The 60 GB store volume is a disposable GHCR mirror: the nbg1→hel1 migration recreates it fresh and it re-fills from GHCR on the next CI dual-push. Hosts pull the SAME @sha256 digests here (crane-copy from CI preserves them); cosign verifies the zot-stored .sig offline against the unchanged pinned root. Plain-HTTP on the private net (integrity via cosign digest-pinning, not TLS); dark-launch gated with an atomic GHCR fallback until the Phase-5 soak retires GHCR push."
  }
  // Modeled #6698: the GitHub Pages custom-domain cert is issued by Let's Encrypt
  // via ACME HTTP-01, and that validation path was entirely absent from the model
  // even though a wedged `bad_authz` authorization is a recurring live incident.
  letsencrypt = system "Let's Encrypt" {
    #external
    description "ACME CA issuing the GitHub Pages custom-domain TLS cert for soleur.ai/www (ADR-125, #6657/#6698). Validation is HTTP-01 against GitHub's origin, which is why remediation must transiently flip apex+www to DNS-only — a Cloudflare-proxied record makes LE see CF anycast instead of GitHub's 185.199.x. TWO properties drive the design: (1) LE PREFERS IPv6 and retries over IPv4 only on a NETWORK-level failure of the first request (redirects get no retry), so a proxied AAAA that answers 200 with the wrong content defeats validation at any window length with no fallback — the propagation gate therefore requires AAAA ENODATA and treats a surviving AAAA as terminal, not retryable; (2) failed-validation rate limits are 5 per identifier per account per hour, refilling ~1 per 12 min with a compounding daily cap, and GitHub surfaces NONE of it — `GET /pages` returns the same `bad_authz` string whether the cause is DNS, timing, or a rate-limit pause. That invisibility is why probe-only mode (which consumes no validation attempt) is the DEFAULT for manual fires."
  }

  // Modeled #6698: the propagation gate reads PUBLIC recursive resolvers rather
  // than the container's, so they are a real external dependency of the
  // remediation path — the container's own resolver may be cached or
  // split-horizon and says nothing about what Let's Encrypt will see.
  publicResolvers = system "Public DNS resolvers" {
    #external
    description "Cloudflare 1.1.1.1 and Google 8.8.8.8, queried via node:dns Resolver.setServers() by cron-gh-pages-cert-reissue's DNS-propagation gate (#6698). Used to confirm the DNS-only flip actually reached the public internet before the cert poll begins — Cloudflare's TTL for proxied records is fixed at 300 s, so a proxy-status flip takes ~5-10 min to propagate and a poll started before then is guaranteed-wasted public-TLS-outage window. `dig` is deliberately NOT used: it is not installed in the app image (the Dockerfile installs only ca-certificates, git, bubblewrap, socat, qpdf, jq), so shelling out would throw at runtime."
  }

  betterstack = system "Better Stack" {
    #external
    description "External uptime/heartbeat monitoring (BetterStackHQ/better-uptime) AND a Logs warehouse (source 2457081, ClickHouse-SQL-queryable) that CI polls read-only. Apex + inngest + registry-disk heartbeats, plus (#6438/#6548) TWO new per-host web heartbeats — web_zot_consumer (the zot-consumer serviceability probe, #6438 §1) and web_nic_guard (the §3 private-NIC-guard liveness beat, #6438 §3), both for_each var.web_hosts — and git-data, which is now FED by the web-host git-data consumer probe (#6548): its git_data_prd beat was previously unfed (no probe cron was ever written) and absent from live Better Stack despite having no count gate, and is now armed via the ADR-117 measure-then-arm gate. Registry-liveness remains paused until #6537's feeder ships and a beat is measured. All three new/newly-fed web beats (web_zot_consumer, web_nic_guard, git_data_prd) are arm-gated by the automated measure-then-arm PATCH in apply-web-platform-infra.yml (ADR-117 amendment #6438). ALSO a per-host origin absence detector that probes each web host's CF-proxied hostname (web-N.app.soleur.ai/health) directly, so a dead/never-booted host pages with per-host attribution the round-robin monitors cannot give (#5933 Item 1). The Logs source receives SOLEUR_ZOT_DISK + SOLEUR_PRIVATE_NIC self-reports from the deny-all registry host AND SOLEUR_PRIVATE_NIC from web-1 (the §3 web-host guard, detect+emit+alarm, NO reboot — ADR-123) and is polled from GitHub Actions via betterstack-query.sh for the zot restart-loop recurrence alarm (#6291) + follow-through soak probes — log-content recurrence alarms are in-repo GH-cron pollers, not native Better Stack alerts (ADR-096)."
  }
  // The error-tracking + alerting plane, managed as IaC (ADR-031, apps/web-platform/infra/sentry/).
  // Modeled late (#6436): it was absent while the narrower `betterstack` was present, so the C4
  // implied the platform had no alerting at all.
  sentry = system "Sentry" {
    #external
    description "Error tracking + alerting, Sentry-as-IaC (ADR-031; apps/web-platform/infra/sentry/, auto-applied on push to main by apply-sentry-infra.yml — its `paths:` filter is the whole `infra/sentry/**` tree and the plan is FULL-ROOT since #6589, so declaring a resource applies it and DELETING one really destroys it, gated pre-merge by `sentry-destroy-required` + `[ack-destroy]`. The filter was widened from a 3-file list because the retired `-target=` allowlist had doubled as the gate for declared-but-never-applied). Org `jikigai-eu` on the EU/DE cluster. TWO distinct hostname classes: the Terraform/dashboard API is the ORG SUBDOMAIN (`https://<org>.sentry.io/api/`, see main.tf's provider block — NOT `eu.sentry.io`, whose regional host rewrites `-eu`-suffixed slugs to the literal `eu` org via an activeorg-cookie hijack, 302→401, breaking every read/write); DSN ingest is `de.sentry.io` (DE residency, Art. 30 PA8 §(e)). Holds the LARGER of the two paging surfaces: the issue alerts (issue-alerts.tf), the cron monitors (cron-monitors.tf — one per scheduled workflow, `failure_issue_threshold` opens an issue on a missed check-in) and the uptime monitors (uptime-monitors.tf). It is a no-SSH paging path — a host that never finished booting still pages through here. It is deliberately NOT the only one: `betterstack` is a SECOND-SOURCE vendor that pages independently precisely so a Sentry outage is survivable (see its own edge to founder). Do not 'consolidate' the two — the redundancy is the design."
  }
  sigstore = system "Sigstore" {
    #external
    description "Keyless container-image signing/verification (cosign/Fulcio/Rekor). The release CI keyless-signs the pushed web app image digest (this IS a live sigstore call — github → sigstore below). The host then cosign-verifies the signature FULLY OFFLINE against a pinned trusted_root.json — it makes NO live sigstore call at verify time (ADR-087, #6005) — supply-chain authenticity for the shared host (#5933 Item 4)."
  }

  // External UNTRUSTED plugin SOURCE — the connected repo's OWN committed
  // `plugins/soleur/` directory. When an operator connects a repo that dogfoods
  // Soleur (soleur-in-soleur), that repo's frozen committed plugin copy lands in
  // the user's workspace. It is UNTRUSTED code: its `hooks/hooks.json` registers
  // `type:"command"` hooks that the Agent SDK would run as subprocesses of the
  // Node dispatch process (outside the bwrap tool sandbox, with the server's env +
  // privileges). Distinct from the platform-controlled `plugin` system above. The
  // untrusted-source counterpart to `contributor` (both #external, both gated by an
  // explicit trust boundary — see the `connectedRepoPlugin -> skillloader` edge).
  connectedRepoPlugin = system "Connected-Repo Plugin Copy" {
    #external
    description "The connected repo's own committed plugins/soleur/ dir, present in the user's workspace when they connect a Soleur-dogfooding repo. UNTRUSTED: its hooks/hooks.json command-hooks would run in the Node dispatch process (outside bwrap). INERT for the SDK — both real-SDK factories load plugins:[{path: getPluginPath()}] (the platform-deployed root), never this copy (ADR-093 trust boundary)."
  }

  // ======================================================================
  // Relationships — preserved 1:1 from the three Mermaid sources.
  // ======================================================================

  // ---- C4 L1 (System Context) — 18 relationships -------------------------
  founder -> webapp "Interacts via browser" { technology "HTTPS" }
  webapp -> engine "Thin view/control layer" { technology "WebSocket" }
  webapp -> supabase "Auth and data" { technology "HTTPS" }
  webapp -> stripe "Checkout and billing" { technology "HTTPS" }
  webapp -> plausible "Page view events" { technology "JS snippet" }
  webapp -> github "Reads release notes for the in-app Releases page" { technology "HTTPS (GitHub REST API)" }
  engine -> anthropic "LLM calls with BYOK keys" { technology "HTTPS" }
  engine -> github "Git operations and CI" { technology "HTTPS/SSH" }
  engine -> supabase "Sessions and encrypted keys" { technology "HTTPS" }
  engine -> discord "Notifications" { technology "Webhook" }
  cloudflare -> webapp "Tunnel, DNS, CDN" { technology "HTTPS" }
  // #6698 — the cert-reissue remediation path (ADR-125).
  github -> letsencrypt "Places the ACME order for the Pages custom-domain cert whenever the cname is (re-)set — so every cname toggle consumes a validation attempt against limits that are hourly and COMPOUNDING (5 failures per identifier per account per hour). GitHub surfaces none of it: GET /pages returns bad_authz regardless of cause, which is why probe-only mode exists and is the default (ADR-125, #6698)." { technology "ACME" }
  letsencrypt -> github "ACME HTTP-01 validation of the soleur.ai/www Pages custom domain — reaches GitHub's origin ONLY while apex+www are DNS-only (proxied=false)" { technology "HTTP-01" }
  api -> publicResolvers "DNS-propagation gate: resolve4/resolve6 the apex against 1.1.1.1 + 8.8.8.8 to confirm the DNS-only flip propagated before polling the cert" { technology "DNS (node:dns Resolver)" }
