  // ---- Operational inbox (severity-ranked attention queue, ADR-085 / #6007) --
  // notifyInboxItem inserts the durable row (service role) then dispatches the
  // push/email nudge; GET /api/inbox reads the merged severity-ranked feed
  // (user-context client, RLS Owner-scoped); the inbox_list agent tool reads the
  // same merged feed (agent-native parity).
  webapp -> operationalInbox "notifyInboxItem writes inbox_item + GET /api/inbox reads the merged feed (RLS Owner-scoped)" { technology "PostgreSQL / PostgREST" }
  engine -> operationalInbox "inbox_list agent tool reads the same merged severity-ranked feed (agent-native parity)" { technology "MCP tool → PostgREST" }

  // Beta-CRM (ADR-102): two access paths now exist. The agent WRITES + reads via
  // crm_* MCP tools (mig 126); the read-only UI phase (mig 127, #6172) adds the
  // `webapp -> crmStore` read edge below. Both reuse the SAME owner-scoped RLS
  // boundary — the `webapp` path via GET /api/crm/* on the SSR cookie client,
  // with the detail read going through the auth.uid()-pinned crm_get_contact_detail
  // audit RPC. There is still deliberately NO `founder -> crmStore` edge (the
  // founder reaches it only through `webapp` or the agent).
  engine -> crmStore "crm_* MCP tools read AND write the owner-private CRM via auth.uid()-pinned RPCs (agent-native parity)" { technology "MCP tool → PostgREST / RPC" }
  webapp -> crmStore "GET /api/crm/* RLS-owner-scoped read routes (board/funnel/detail); crm_get_contact_detail logs each PII read to beta_contact_access_log (Art. 5(2))" { technology "PostgREST / RPC (SSR cookie client)" }
  betaContact -> founder "Conversation PII origin — the operator captures notes about this third party" { technology "Conversation" }

  // ---- fix-constraints two-stage privileged recovery boundary (ADR-074) ----
  // Trust boundary: the untrusted contributor's PR-head code runs ONLY in the
  // Stage A producer (read-only, no secret/write); the privileged Stage B
  // consumer — always run by GitHub from the default branch — opens a data-only
  // draft follow-up PR into the product codebase via the Git Data API (no
  // untrusted checkout, structurally clearing the toctou sink).
  contributor -> github "Opens untrusted PR — head code runs in fix-constraints Stage A (pull_request, contents:read, no write token) (ADR-074)" { technology "HTTPS" }
  github -> webapp "fix-constraints Stage B (workflow_run, PRIVILEGED, contents:write): opens a data-only draft follow-up PR via Git Data API — never checks out the untrusted tree (ADR-074)" { technology "HTTPS (Git Data API)" }

  // ---- C4 L2 (Container) — 24 relationships ------------------------------
  founder -> dashboard "Browses and converses" { technology "HTTPS" }
  dashboard -> api "Calls" { technology "HTTPS" }
  api -> claude "Spawns agent sessions" { technology "WebSocket" }
  claude -> skillloader "Loads plugin from the PLATFORM-DEPLOYED root (getPluginPath(), /app/shared/plugins/soleur) — never the connected-repo workspace copy (ADR-093)" { technology "File I/O" }
  // ---- SDK plugin-source trust boundary (ADR-093, fix-plugin-shadow-deployed-load) --
  // The untrusted connected-repo committed plugins/soleur/ is IGNORED by the loader:
  // both real-SDK factories (cc-dispatcher.ts + agent-runner.ts startAgentSession)
  // bind plugins:[{path: getPluginPath()}] (the platform-deployed root, workspace-
  // independent, boot-validated by verifyPluginMountOnce). Loading the workspace copy
  // would execute its hooks.json command-hooks in the dispatch process (outside bwrap)
  // AND silently shadow every platform plugin fix (#4826 delivery wedge). Even the
  // residual in-process SKILL.md reader (context-queries-hook) sources from the
  // deployed root. See knowledge-base/.../2026-07-06-connected-repo-shadows-deployed-plugin-*.md.
  connectedRepoPlugin -> skillloader "IGNORED by the loader (trust boundary): the committed workspace plugins/soleur/ is never the SDK load source — getPluginPath() (deployed root) is. Loading it would exec the repo's hooks.json in-process + shadow platform fixes (ADR-093, #4826)" { technology "File I/O (rejected)" }
  skillloader -> skills "Discovers" { technology "Directory scan" }
  skillloader -> agents "Discovers" { technology "Recursive scan" }
  hooks -> claude "Guards tool calls" { technology "Event hook" }
  hooks -> kb "Reads context_queries artifacts (skill-scoped injection)" { technology "File I/O" }
  api -> kb "Reads context_queries artifacts (skill-scoped injection, web in-process)" { technology "File I/O" }
  skills -> kb "Reads/writes" { technology "File I/O" }
  agents -> kb "Reads/writes" { technology "File I/O" }
  api -> supabase "Auth and data; per-call audit_github_token_use write for every GitHub App-token use (reads AND Workstream issue writes, Art. 30 PA-16, ADR-109)" { technology "HTTPS" }
  claude -> supabase "Sessions and keys" { technology "HTTPS" }
  claude -> anthropic "LLM calls" { technology "HTTPS" }
  api -> anthropic "Daily org cost/usage report (Admin API, cost-report cron)" { technology "HTTPS" }
  claude -> github "Git operations" { technology "HTTPS/SSH" }
  tunnel -> coordinator "Routes traffic" { technology "HTTPS" }
  // #6425: the tunnel's ACTUAL ingress delivery, previously unmodelled — `tunnel -> coordinator`
  // above models the DEFERRED 3.D rewire, not today's path. Since #6594/PR-A, deploy./ssh. address
  // web-1's private IP (10.0.1.10) directly, so this edge terminates on web-1 no matter which host
  // holds the connector — determinism is now STRUCTURAL (origin-relative ingress), not a property
  // of there being exactly one connector (there are two live in prod; ADR-114 I1 is a create-time
  // gate that never re-ran on the already-booted fleet).
  tunnel -> hetzner "deploy. → http://10.0.1.10:9000 (webhook) and ssh. → ssh://10.0.1.10:22 — ORIGIN-RELATIVE to web-1's private IP since #6594/PR-A (was localhost:, the ADR-114 I2 anti-pattern). Whichever connector replica CF selects now proxies to web-1, the only host that serves these routes — so the edge is deterministic BY CONSTRUCTION (I2 discharged), not merely 'inert while one connector holds'. Matches the registry. edge, already origin-relative (10.0.1.30). /hooks/deploy still fans out to peers over the private net (ADR-068 Option B); deploy-status, inngest-liveness and infra-config do NOT fan out — with the origin-relative pin they no longer need to, since they answer from web-1 regardless of colo." { technology "cloudflared ingress → 10.0.1.10 (ORIGIN-relative — ADR-114 I2 discharged, #6594)" }
  // #6416 / ADR-114 — the tunnel's three ingress rules, made explicit. The registry edge is
  // the ONLY origin-relative one (it addresses 10.0.1.30 directly), which is why it is the
  // pattern to generalize; the other two are connector-relative (`localhost:`) and therefore
  // resolve to whichever replica CF load-balanced onto, NOT to a chosen host.
  tunnel -> zotRegistry "registry. ingress → tcp://10.0.1.30:5000. ORIGIN-RELATIVE — whichever connector replica answers proxies to the correct zot host, but ONLY if that replica is a 10.0.1.0/24 member (ADR-114 I1). #6416 (historical): web-2 was not a subnet member, so CI's registry bridge failed and the zot mirror silently skipped (masked green by continue-on-error). web-2 was retired 2026-07-17 (#6538); the surviving web-1 connector is a subnet member, so this failure mode is closed." { technology "cloudflared access tcp → raw TCP over WebSocket (tcp://, NOT http:// — #6122)" }
  github -> tunnel "CI reaches the deny-all-public zot host to dual-push release images, and reaches web-1's shell for the 12 terraform_data SSH provisioners — both ONLY through this tunnel, via CF Access service tokens (separate tokens per route, so registry-write rotates independently of host-shell access)" { technology "cloudflared access tcp/ssh (CF Access service token)" }
  hetzner -> tunnel "ONE web host runs a cloudflared connector in prod (web-1); web-2 was retired 2026-07-17 (#6538/#6463) and var.web_hosts is single-host. Historically TWO were live: the server.tf web_tunnel_connector gate (#6425) was meant to leave only web-1, but it lives at cloud-init create-time user_data and hcloud_server.web has ignore_changes=[user_data], so it never re-ran on web-2 (booted 2026-07-13, before the gate merged 2026-07-15). Registration is ALSO NIC-gated at first boot since #6441 (ADR-114 I1): runcmd waits for the host's expected private address before `cloudflared service install`, then defers rather than aborting — post-#6594 a connector without its private NIC serves NOTHING, since all three ingress services are private-IP-relative. Like the #6425 gate this is create-time user_data only, so NO gate re-runs on a host that is already up: web-1's LIVE registration is not NIC-gated and never will be by this mechanism. So ssh:// and deploy. ingress are NOT deterministic by one-connector — they are deterministic because #6594/PR-A made their services origin-relative to web-1 (ADR-114 I2 discharged). CF still picks a connector per edge colo; the origin-relative pin makes that choice irrelevant to correctness. NOTE: the 'in-band hostname tripwire' this edge previously credited to the SSH provisioners does NOT exist — measured 2026-07-17, zero host-identity assertions in the 12 connection{} inlines (ADR-068:413's claim is false). The only retained absorption layer is ADR-068's private-net fan-out (deploy only)." { technology "cloudflared (outbound QUIC; ONE connector live: web-1)" }
  hetzner -> claude "Hosts" { technology "Docker" }
  hetzner -> workspacesVolume "Stores every user's checked-out repository. Mounted at /mnt/data and bind-mounted into the app container as /workspaces (cloud-init.yml). The app container is the SOLE writer, which is what makes a container stop a sufficient freeze for the ADR-119 cutover — though `docker stop` defaults to a 10s grace then SIGKILL, so the cutover uses -t 120 plus interrupted-write asserts: a truncated file is otherwise rsynced and certified correct" { technology "ext4 on a Hetzner block volume (plaintext at rest — ADR-119 in progress; the 2026-07-20 cutover landed and was auto-reverted by its dead-man 27 min later, #6812)" }
  doppler -> hetzner "Injects the web-host boot credential. The LUKS-at-rest passphrase (WORKSPACES_LUKS_KEY, ADR-119) is deliberately scoped to a DEDICATED prd_workspaces_luks config read by a read-only host token — NOT the shared soleur/prd config. Rationale is host-vs-CONTAINER, not host-vs-host (web-1 already carries full-prd, so there is no host blast radius left to buy): cloud-init runs `doppler secrets download --config prd` into the TMPENV that feeds `docker run --env-file`, so a key in shared prd would be readable via /proc/self/environ by the very agent code whose data it encrypts (CWE-522). The #6649 header-escrow R2 S3 creds (WORKSPACES_HEADER_R2_ACCESS_KEY_ID/_SECRET_ACCESS_KEY) + bucket name + endpoint are delivered via the SAME prd_workspaces_luks scoped read — never on the cutover's sudo argv" { technology "CLI (doppler run / scoped read-only service token)" }
  hetzner -> cloudflare "Uploads the LUKS header backup off-host to an R2 bucket (soleur-workspaces-luks-header) DISTINCT from the tfstate bucket (C4 escrow, ADR-119 #6649) — a BLOCKING pre-freeze gate: no off-host header ⇒ the cutover aborts before touching sole-copy data. LIMITATION: this single edge collapses BOTH R2 buckets (tfstate + header) into the one cloudflare node, so it does NOT visually encode the 'distinct blast radius' property — that lives only at runtime (workspaces-cutover.sh:185) + the workspaces-luks-header.test.sh reference-not-literal guard" { technology "aws-cli s3 (R2 S3-compat, --endpoint-url)" }
  doppler -> claude "Injects secrets" { technology "CLI" }
  auth -> supabase "Validates tokens" { technology "HTTPS" }
  api -> stripe "Checkout and webhooks" { technology "HTTPS" }
  claude -> stripe "invoice skill: create/finalize/send/chase via hosted Stripe MCP — OAuth, operator's OWN account; distinct credential plane from the webapp -> stripe billing edge; test-mode only in v1 (ADR-107)" { technology "MCP tool → mcp.stripe.com (HTTPS)" }
  api -> github "Workstream tab: reads connected-repo issues (REST) + Project v2 board Status (GraphQL); AND writes issues — create / title / label-driven status / close-reopen — via the audited GitHub App-token client (ADR-109). The board is the canonical Status store (ADR-097); a status write is a label mutation that the board-status-sync workflow (github-internal) mirrors. owner/repo/installation resolve from the active workspace (ADR-044), never request input. ALSO Pages cert admin: the cron-gh-pages-cert-reissue routine (served by this container, event-triggered) does PUT /pages cname-toggle to re-order a bad_authz TLS cert via a least-privilege App token holding BOTH administration:write AND pages:write — PUT /pages requires both, proven empirically (pages-only 403, admin-only 403, both 204); GitHub's REST docs do not state it (ADR-125, #6698)." { technology "HTTPS (REST + GraphQL)" }
  api -> cloudflare "cron-gh-pages-cert-reissue (ADR-125, AP-019): transiently PATCHes the apex+www dns_records proxied flag false→true to open a DNS-only window so GitHub/LE can validate the Pages cert origin, then restores proxied=true. A distinct Zone.DNS:Edit-only token (CF_API_TOKEN_DNS_EDIT), separate from the broad cf_api_token. This is the sanctioned narrow AP-001 exception — transient, self-reverting, single-attempt, human-gated (v1)." { technology "HTTPS (CF API v4 dns_records PATCH)" }
  dashboard -> plausible "Page view events" { technology "JS snippet" }
  api -> inngest "Sends events; serves functions" { technology "HTTP private-net :8288" }
  resend -> api "Inbound email webhook (svix-verified) → email-triage ingress" { technology "HTTPS" }
  api -> resend "Statutory triage notifications (single configured recipient; reads are Owner-shared per ADR-066)" { technology "HTTPS" }
  inngest -> supabase "Email-triage claim/finalize writes (email-on-received)" { technology "PostgreSQL" }
  inngest -> inngestPostgres "Config + run history" { technology "PostgreSQL session pooler :5432" }
  inngest -> inngestRedis "Durable queue + run-state" { technology "Redis (AOF)" }
  inngest -> betterstack "Ships journald + host_metrics via Vector (arm64, aarch64 build) to Logs source 2457081; token in soleur-inngest/prd (ADR-100 Phase-1 caveat resolved, #6197). Source 2457081 is NOT isolated to this node — the web hosts ship to the SAME source (see the hetzner edge), and the two are told apart only by the per-host host_name discriminator, which web-1 currently POISONS: web-1 wears this node's host_name=soleur-inngest-prd until its recreate clears the stale label (#6616). The dedicated node's telemetry host (auto OS hostname) is soleur-inngest, which equals its hcloud_server.inngest name (inngest-host.tf) — NOT soleur-inngest-server-prd, which is a Better Stack heartbeat monitor name (inngest.tf), never a telemetry value" { technology "Vector → Better Stack Logs (HTTPS)" }
  hetzner -> betterstack "Ships journald + host_metrics via Vector to the shared Logs source 2457081 (per-host host_name discriminator; token BETTERSTACK_LOGS_TOKEN in soleur/prd); ungated from web_colocate_inngest so every web host ships logs post-ADR-100 (#6396). CREATE-TIME-RENDER CAVEAT (#6616, same class as the tunnel-connector coin-flip): the per-host host_name is a construction-time render, so web-1 — which predates #6396 and, under lifecycle{ignore_changes=[user_data]}, never re-ran cloud-init — still ships host_name=soleur-inngest-prd (its inngest-owned vector.service from the co-located era), colliding on source 2457081 with the dedicated Inngest node until web-1's next recreate. The invariant is enforced by the #6616 follow-through, not by the render alone" { technology "Vector → Better Stack Logs (HTTPS)" }
  hetzner -> inngest "Hosts (dedicated single-host node, private-net 10.0.1.40; removed from web cloud-init — ADR-100, #6178)" { technology "systemd" }
  hetzner -> zotRegistry "Pulls app image + baked bootstrap scripts/hooks + the cosign .sig at boot/deploy — zot-primary, dark-launch gated (attempts zot only when configured + /v2/-reachable + login ok); the SAME @sha256 digest dual-pushed from CI; verify is offline against the unchanged pinned root, no live sigstore call (ADR-096, #6122)" { technology "Docker/zot (private-net, plain-HTTP + insecure-registries)" }
  hetzner -> ghcr "Atomic fallback pull when zot is unconfigured/unreachable — dual-pushed + break-glass through the Phase-5 soak, then retired; authenticated (read:packages), immutable @sha256 digest, offline cosign verify (#5921, #5887, #6005)" { technology "Docker/GHCR (authenticated, fallback)" }
  // #6438 §1 — the CONSUMER-perspective ("L3") private-net probe. The web host verifies from its
  // OWN vantage that it can actually SERVE an image from zot over the private net: an authenticated
  // (htpasswd Basic auth) HEAD of a known manifest at 10.0.1.30:5000 (200=servable→ping,
  // 404=store empty/detached→suppress, 401=auth broke=HARD fail). Closes the gap L1/L2 (ADR-115) +
  // the registry self-ping cannot see: the private net broken from a CONSUMER's view while the
  // registry thinks its own NIC is fine (#6400 shape). Feeds web_zot_consumer via a systemd timer.
  hetzner -> zotRegistry "CONSUMER serviceability probe (#6438 §1): web-zot-consumer-probe.sh HEADs a known manifest over the private net (authenticated htpasswd Basic auth) and pings the per-host web_zot_consumer heartbeat only on a 200; 404 (empty/detached store) suppresses the ping so absence alarms; 401 is a HARD auth failure, not 'alive'. Distinct from the pull edge above — this proves the store SERVES, not just that the auth gate answers" { technology "curl -u (private-net, plain-HTTP HEAD /v2/<repo>/manifests/<tag>)" }
  // #6548 — the git-data CONSUMER probe (fail-soft overlay). A bounded SSH connect-and-close to
  // 10.0.1.20:22 proves the private-net path to git transport is reachable; git-data is an OVERLAY
  // (not a hard dependency), so a single transient blip must not page — grace is relaxed and it
  // arms the previously-unfed git_data_prd beat.
  hetzner -> gitDataStore "CONSUMER reachability probe (#6548): web-git-data-probe.sh does a bounded SSH connect-and-close to 10.0.1.20:22 over the private net and pings the git_data_prd heartbeat on success. Fail-soft (connect-and-close, not a git ls-remote — the accepted reachability-vs-serviceability tradeoff for a v1 overlay); this is what finally FEEDS git_data_prd, previously unfed" { technology "SSH connect-and-close (private-net, BatchMode ConnectTimeout)" }
  // #6438 §3 / ADR-123 — the web-host private-NIC self-report guard. Same in-surface emit as the
  // registry's SOLEUR_PRIVATE_NIC (this edge is the SECOND source of that event), but the web host
  // makes a STRUCTURALLY DIFFERENT decision: detect + emit + alarm, NO reboot (a web-1 reboot would
  // power-off the sole live origin). Re-anchored to content 2026-07-20 (#6575,
  // cq-cite-content-anchor-not-line-number): this cited apply-web-platform-infra.yml:878, which was
  // inside the `warm_standby` dispatch job deleted with the web-2 sweep — that line number now
  // points at unrelated apply-job SSH-key setup. The reasoning stands on its own. Cites ADR-115's reboot
  // blockers as the REASON it does not self-converge; remediation deferred to #6459 + operator.
  hetzner -> betterstack "Ships SOLEUR_PRIVATE_NIC from web-1 (the §3 private-NIC guard, #6438 §3/ADR-123) to the shared Logs source 2457081 — detect + emit + alarm, NO reboot (unlike the registry's self-converging guard). ALSO pings the web_nic_guard liveness heartbeat every healthy run so the fault-emitter is observable-when-healthy (a SOLEUR_PRIVATE_NIC that never fires is indistinguishable from a dead guard). Distinct from the Vector journald edge above" { technology "curl → Better Stack Logs + heartbeat (HTTPS)" }
  betterstack -> hetzner "Origin uptime probe at the LB-fronted app.soleur.ai surface (betteruptime_monitor.app/soleur_apex) — covers web-1 (the app A-record → web-1, dns.tf); the #5933 per-host web-<n> probe was RETIRED (CF 521, no per-host origin vhost). web-2 (the fsn1 warm standby) was retired 2026-07-17 (#6538/#6463) — the fleet is single-host, fully covered by the app.soleur.ai probe; no second host needs separate uptime coverage" { technology "HTTPS via CF edge" }
  github -> sigstore "Keyless-signs the released app image digest (cosign, OIDC→Fulcio→Rekor) (#5933 Item 4)" { technology "HTTPS (cosign)" }
  // ADR-133 / #6780 — the config-refresh channel for the dedicated Inngest host. CI ALSO
  // keyless-signs a SECOND artifact (the config bundle's manifest blob), dual-pushes it to
  // GHCR + zot, and the inngest host pulls+verifies+applies it in-place. Distinct from the
  // app-image edges above: a different OCI repo, a `sign-blob`/`verify-blob` shape (not image
  // sign), and a monotonic VERSION carried INSIDE the signed bytes (HARD-2). The host-side pull
  // edge is `adopting` — it activates when the consumer bake rides the #6178 cutover (PR #6348).
  github -> sigstore "Keyless-signs the config-refresh bundle manifest (cosign sign-blob, OIDC→Fulcio→Rekor) — the *.sh in-place refresh channel for the sole Inngest scheduler (ADR-133, #6780)" { technology "HTTPS (cosign sign-blob)" }
  github -> ghcr "Dual-pushes the keyless-signed config-refresh bundle (host-executed *.sh set + per-file sha256 manifest + signed monotonic VERSION) to GHCR + zot; a Terraform-promoted INNGEST_CONFIG_DIGEST pointer in soleur-inngest/prd names the digest (ADR-133/ADR-128, #6780)" { technology "oras push (OCI artifact, GHCR + zot dual-push)" }
  inngest -> ghcr "ADOPTING (rides #6178 cutover, PR #6348): the config-refresh timer resolves INNGEST_CONFIG_DIGEST, pulls the signed bundle @sha256 GHCR-direct, cosign-verify-blob OFFLINE against the baked trusted root + config-workflow identity regexp (ADR-087), checks per-file sha256 + monotonic VERSION, and applies atomically via infra-config-install.sh — no host replace, outbound-only, no new inbound (ADR-133, #6780)" { technology "Docker/GHCR pull + cosign verify-blob (offline)" }
  // NOTE: the former `hetzner -> sigstore` verify edge was REMOVED (#6005/ADR-087) — it was
  // falsified: with a pinned local trusted_root.json + offline verify the host makes NO live
  // sigstore call at verify time. The signature bundle is fetched from `ghcr` (edge above).
  doppler -> inngest "Injects secrets — dedicated host's boot credential is scoped to the SEPARATE Doppler project `soleur-inngest` (its own `prd` root holds only inngest secrets: Postgres URI, freshly-rotated signing/event keys, Redis pw), NOT a `prd` branch config that would inherit all ~116 soleur/prd secrets (ADR-100, #6178; mirrors the soleur-registry isolation #6122)" { technology "CLI (doppler run soleur-inngest)" }
  // #6122 (ADR-096, isolation amendment) — the registry host's boot credential is scoped to a
  // SEPARATE Doppler project `soleur-registry` (its own `prd` root holds ONLY the 2 ZOT htpasswd
  // tokens), NOT a `prd` branch config that would inherit all 116 soleur/prd secrets. #6167 audits
  // the sibling branch-config over-reads (prd_git_data / prd_kb_drift_walker / prd_cla).
  doppler -> zotRegistry "Injects the registry-host boot credential (scoped to the isolated soleur-registry project's prd root — the 3 admitted secrets ZOT_PULL/PUSH_TOKEN + BETTERSTACK_LOGS_TOKEN, no soleur/prd inheritance)" { technology "CLI (doppler run soleur-registry)" }
  // #6244 (ADR-096, disk-observability amendment) — the deny-all-ingress, no-SSH registry host
  // self-reports its disk state directly to Better Stack Logs (was a heartbeat pinger only, via
  // the web-host probe). SOLEUR_ZOT_DISK is the in-surface probe that disambiguates
  // fs-not-grown / gc-too-slow / zot-crash without a host login.
  // #6415 / ADR-115 — a SECOND event type on this same edge: SOLEUR_PRIVATE_NIC. The host
  // self-asserts that its private IP is configured. It is emitted FROM the affected (blind)
  // surface because a NIC-less host keeps PUBLIC egress, so every off-host signal stays green
  // while the fleet's primary pull path is dead (#6400: 14 days).
  zotRegistry -> betterstack "Ships disk-state observability — df% of /var/lib/zot + resize2fs before/after + zot health — as one SOLEUR_ZOT_DISK event, plus a SOLEUR_PRIVATE_NIC private-NIC convergence event (#6415), to the isolated Logs source 2457081; token in soleur-registry/prd, queried via betterstack-query.sh --grep SOLEUR_ZOT_DISK|SOLEUR_PRIVATE_NIC (#6244/#6415). ALSO pushes two distinct absence-based heartbeats, whose scopes must not be conflated: the 900s disk beat pings on df alone, so it alarms HOST death but stays green with zot dead; the 60s liveness beat (zot-liveness-heartbeat.timer, #6537) pings ONLY while zot answers on the host's own PRIVATE IP — never loopback, since zot binds 0.0.0.0 and loopback answers on a NIC-less host (#6400). The liveness beat's monitor stays PAUSED until #6537's post-merge reprovision measures a real beat and arms it; consumer-perspective reachability is unbuilt (#6438 §1)" { technology "curl → Better Stack Logs + heartbeats (HTTPS, eu-fsn-3)" }
  // #6291 — CI reads back the SOLEUR_ZOT_DISK Logs source it ships to. The standing restart-loop
  // recurrence alarm (scheduled-zot-restart-loop.yml, */30) + the follow-through soak probes poll
  // source 2457081 over the ClickHouse SQL API; previously an un-modelled load-bearing edge.
  // #6415 — the same alarm now ALSO polls SOLEUR_PRIVATE_NIC and carries an independent NIC
  // verdict (not folded into its exit code, so a NIC fire is never mis-reported as a probe fault).
  github -> betterstack "Polls the SOLEUR_ZOT_DISK + SOLEUR_PRIVATE_NIC Logs sources (ClickHouse SQL via betterstack-query.sh) for the zot restart-loop recurrence alarm, the private-NIC convergence alarm (#6415), and follow-through soak probes. ALSO reads the heartbeats API read-only (GET /api/v2/heartbeats) from the scheduled-terraform-drift.yml heartbeat-live-reconcile job (#6549 item 2): it reconciles the LIVE paused/existence of each monitored heartbeat against the executable MANIFEST (heartbeat-manifest.ts) and flags fed-but-paused (the #6537 shape) or non-count-gated-absent-live (the #6548 git-data shape) — the live-state layer ADR-117's static guard cannot see. Distinct surface from the Logs poll above" { technology "HTTPS (ClickHouse SQL Logs + Uptime heartbeats API, eu-fsn-3)" }

  // ---- Sentry — the LARGER of two alerting planes (#6436, ADR-031) --------
  // Three emitters + a paging exit. It is NOT the only exit: `betterstack` pages
  // independently (see its edge to founder) — that second source exists so a Sentry
  // outage is survivable, and it is the property most worth not "simplifying" away.
  //
  // Deliberately NO `inngest -> sentry` edge: the Inngest Server host has no Sentry path
  // — its Vector sink was pivoted OFF Sentry's HTTP envelope endpoint onto Better Stack
  // Logs after ~6 PR cycles of interop failures (#4273; grep `[sinks.betterstack]` in
  // inngest.tf and the pivot note in inngest-bootstrap.sh). The Inngest-FIRED crons'
  // check-ins are posted by the code `api` serves (the `api -> inngest "serves functions"`
  // edge above), i.e. on the `webapp` edge below — EXCEPT the two Inngest-dispatched
  // monitors noted on the `github` edge, which check in from GitHub Actions.
  // Anchored on grep-able tokens, not line numbers — #6447's own rule, which this PR's
  // first draft broke here by minting fresh `file:<N>` citations into the C4.
  hetzner -> sentry "Host-side fatal + deploy telemetry, POSTed straight to the store API with the baked ${sentry_dsn} — the boot fatal-emit trap armed at the TOP of `runcmd:` in cloud-init.yml (before Doppler exists), ci-deploy.sh's deploy/sandbox-canary/cosign-verify/zot-fallback events, and container-restart-monitor.sh. Fail-open and SSH-free by construction: this is how a host that never finished booting still pages" { technology "HTTPS (Sentry store API, X-Sentry-Auth sentry_version=7)" }
  webapp -> sentry "Exceptions + debounced warns via the @sentry/nextjs SDK (sentry.client.config.ts / sentry.server.config.ts / instrumentation.ts, SENTRY_DSN) — the stack-keyed capture shape the issue alerts group on; AND the Inngest-fired crons' end-of-run check-ins (`postSentryHeartbeat` in _cron-shared.ts → /api/{id}/cron/{slug}/{key}/?status=ok|error, bounded retry #5728) that satisfy the 43 Inngest-substrate sentry_cron_monitors" { technology "HTTPS (Sentry SDK envelope + cron check-in API)" }
  github -> sentry "CI is both an emitter and the applier: the ./.github/actions/sentry-heartbeat composite posts ok|error check-ins from 6 workflows — 3 GHA-`schedule:`-fired (scheduled-inngest-health, -zot-restart-loop, -realtime-probe) and 3 `workflow_dispatch`-only that Inngest DISPATCHES per ADR-033 (scheduled-terraform-drift, -domain-model-drift, -supabase-advisor-scan). Those 3 are the third substrate: Inngest-scheduled but GHA-executed, so their check-in rides this edge, not webapp's. Of 50 cron monitors, 7 check in from here and 43 from webapp. apply-sentry-infra.yml also auto-applies the sentry root on push to main via the jianyuan/sentry provider (ADR-031 — no dashboard step; its `paths:` filter is the 3 rule files, not the whole root)" { technology "HTTPS (cron check-in API + Terraform provider, SENTRY_AUTH_TOKEN)" }
  sentry -> founder "Pages the operator — the LARGER of two independent exits (betterstack is the other; a Sentry outage is survivable BY DESIGN). Issue alerts route actions_v2 notify_email → target_type IssueOwners with fallthrough_type ActiveMembers — 21 of the 22 rules; `byok_cap_exceeded` deliberately sets fallthrough_type NoOne. NB IssueOwners has no ownership rule on this project, so the fallthrough is what actually reaches a human: a NoOne rule fires and pages nobody, by design there and a defect anywhere else. The cron monitors open an issue on a missed/failed check-in (failure_issue_threshold = 1) and the uptime monitors on downtime, both of which then fire that same email route" { technology "Sentry issue alert → email notification" }
  // The second-source exit. Load-bearing: uptime-alerts.tf's apex monitor says it plainly
  // — "independent vendor from Sentry. If Sentry itself is degraded ... this monitor still
  // pages." Absent from the model until #6436's review noticed the new sentry->founder edge
  // had claimed exclusivity it does not have.
  betterstack -> founder "Pages the operator INDEPENDENTLY of Sentry — the second source. The apex uptime monitor and the inngest + registry-disk heartbeats alert on downtime/missed beats (the git-data heartbeat does NOT — it is unfed and absent live, #6548; the registry LIVENESS heartbeat does not yet either — its feeder ships in #6537 and it is armed only once a real beat is measured post-reprovision); on the free tier this is email to the managed recipient, escalating via betteruptime_policy when var.betterstack_paid_tier is set. This is the exit that survives a Sentry-side outage, which is the entire reason the vendor is duplicated" { technology "Better Stack monitor/heartbeat → email (+ policy escalation on paid tier)" }
  // #6031 / ADR-088 — control-plane GHCR installation-token minter (cron-ghcr-token-minter,
  // every 20 min). Mints a 1h packages:read App installation token and writes it to Doppler,
  // retiring the interim read:packages PAT; hosts read GHCR_READ_TOKEN unchanged.
  inngest -> github "Mints packages:read installation token every 20 min (ADR-088)" { technology "HTTPS (GitHub App JWT → /app/installations/{id}/access_tokens)" }
  inngest -> doppler "Writes GHCR_READ_TOKEN (1h scoped, prd_ghcr) (ADR-088)" { technology "HTTPS (Doppler REST API)" }

  // ---- C4 L2 — Multi-host /workspaces cluster (ADR-068, #5274) -----------
  // tunnel -> coordinator (above) replaces the former tunnel -> api ingress.
  coordinator -> claude "Places/routes sessions (lease-keyed)" { technology "HTTPS (private net)" }
  coordinator -> supabase "Reads worktree lease" { technology "PostgreSQL" }
  api -> sessionStore "Session/replay state" { technology "Redis (TLS)" }
  claude -> sessionStore "Replay buffer + control state" { technology "Redis (TLS)" }
  claude -> gitDataStore "Bare repo data; worktrees local" { technology "git over private net" }
  scheduler -> hetzner "Schedules" { technology "Nomad" }

  // ---- C4 L3 (Component — Soleur Plugin) — 21 relationships --------------
  // (the L3 `hooks -> claude` edge is identical to the L2 one above and is not
  //  re-declared; it still renders in the component view, which includes both.)
  go -> brainstorm "Routes explore/generate"
  go -> oneshot "Routes build"
  oneshot -> plan "Step 1"
  oneshot -> work "Step 2"
  oneshot -> review "Step 3"
  oneshot -> compound "Step 4"
  oneshot -> ship "Step 5"
  brainstorm -> cto "Phase 0.5 assessment"
  brainstorm -> cmo "Phase 0.5 assessment"
  brainstorm -> cpo "Phase 0.5 assessment"
  plan -> cto "Phase 2.5 domain review"
  review -> archstrat "Parallel review agent"
  cto -> architecture "Recommends ADR creation"
  archstrat -> architecture "Checks ADR coverage"
  claude -> go "User invokes /soleur:go"
  brainstorm -> kb "Writes brainstorms"
  plan -> kb "Writes plans and specs"
  work -> kb "Reads plans, writes code"
  compound -> kb "Writes learnings, promotes to constitution"
  architecture -> kb "Writes ADRs and diagrams"
  compound -> evalharness "Validates classifier-skill edits before applying"
  constraintscaffold -> webapp "Generates L1 import-boundary gate (CI)"
}
