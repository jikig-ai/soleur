                      "content": "Feature: KB Chat Sidebar",
                      "fontFamily": "Cormorant Garamond",
                      "fontSize": 36,
                      "fontWeight": "500"
                    },
                    {
                      "type": "frame",
                      "id": "jwYJL",
                      "width": "fill_container",
                      "height": 8,
                      "fill": "#0F0F0F"
                    },
                    {
                      "type": "text",
                      "id": "zGMbj",
                      "fill": "#C9A962",
                      "content": "PROBLEM STATEMENT",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "600",
                      "letterSpacing": 3
                    },
                    {
                      "type": "text",
                      "id": "7Ygrj",
                      "fill": "#848484",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The \"Chat about this\" button on the KB document viewer navigates the user to a full-page chat. This drops the user out of the document they were reading — losing scroll position, breadcrumb context, and the doc itself from sight. Users want to read and ask without leaving the doc, and reference specific passages in their questions.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "sgqpU",
                      "width": "fill_container",
                      "height": 8,
                      "fill": "#0F0F0F"
                    },
                    {
                      "type": "text",
                      "id": "l4c1o",
                      "fill": "#C9A962",
                      "content": "GOALS",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "600",
                      "letterSpacing": 3
                    },
                    {
                      "type": "text",
                      "id": "e8vm8",
                      "fill": "#848484",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Open chat as an in-context panel alongside the KB document.\n• Enable text selection to be sent to chat as quoted context via a pill.\n• Preserve one thread per KB document keyed on context.path.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
