            },
            {
              "type": "frame",
              "id": "QcQUE",
              "name": "notes",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 12,
              "children": [
                {
                  "type": "text",
                  "id": "2YXsL",
                  "name": "n1",
                  "fill": "#CFCFCF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "•  Order — accelerator first (⌘D / Ctrl+D), then the g-leader (G D). Left to right.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7Srcn",
                  "name": "n2",
                  "fill": "#CFCFCF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "•  Spacing — 8px gap between the two hints, no separator glyph. Keeping it a bare gap is the KISS call; a dot or pipe would be clutter.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7ncrv",
                  "name": "n3",
                  "fill": "#CFCFCF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "•  The g-leader is always the last (rightmost) element and flush-right, so it forms one consistent right-hand column across every row.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "JitqW",
                  "name": "n4",
                  "fill": "#CFCFCF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "•  Single-hint rows (Workstream, Knowledge Base) show one hint in that SAME column — the accelerator slot is simply empty, so the asymmetry reads as intentional, not broken.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "NCoB4",
                  "name": "n5",
                  "fill": "#CFCFCF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "•  Both hints reuse .cmdk-keys verbatim: monospace, 0.72rem, colour #8A8A8A. The selected row brightens only the LABEL; hint colour is unchanged.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
    },
