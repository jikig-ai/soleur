    {
      "type": "text",
      "id": "ynSBZ",
      "x": 0,
      "y": 810,
      "name": "ann1",
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "01 — Default sidebar state\nAll file types visible (md, png, csv, pdf)\nType-specific icons per file extension",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "bvKSW",
      "x": 1380,
      "y": 810,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "02 — Hover reveals upload button\nUpload button appears on directory hover\nClicking opens native file picker",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "i8Qjl",
      "x": 2760,
      "y": 810,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "03 — Upload loading state\nFile appears in tree with loading indicator\nToast notification shows commit progress\nTree refreshes automatically on success",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "udZC2",
      "x": 0,
      "y": 1710,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "04 — Image preview with lightbox\nImage rendered inline with metadata\nClick-to-expand opens fullscreen lightbox\nDownload button in header",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "ZDQhl",
      "x": 1380,
      "y": 1710,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "05 — PDF file preview\nBrowser-native PDF embed (<iframe>/<embed>)\nPage navigation via browser controls\nFallback: download link if embed fails",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "eSBrT",
      "x": 2760,
      "y": 1710,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 400,
      "content": "06 — Duplicate file handling (409 response)\nServer detects existing file, returns 409\nModal shows file comparison (existing vs new)\nOverwrite includes SHA in PUT request\nCancel aborts, no commit made",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    },
    {
      "type": "text",
      "id": "vILLA",
      "x": 0,
      "y": 2610,
      "fill": "#A1A1AA",
      "textGrowth": "fixed-width",
      "width": 500,
      "content": "07 — Error states\nFile too large (413): client + server validation, 20 MB limit\nUnsupported type (415): allowlist-only validation\nGitHub API error: surfaces actual error message + retry\nNo repo connected: warning with settings link\nAll errors are dismissible toasts with auto-dismiss",
      "lineHeight": 1.5,
      "fontFamily": "Inter",
      "fontSize": 13
    }
  ]
}